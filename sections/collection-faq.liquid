{% comment %}
  Collection FAQ — hardcoded 3 items, native <details>/<summary>.
  Zero JS. Tuned for Pokemon apparel: fit, print durability, shipping.
  To edit Q&A, change the markup inline below.
  To add a 4th Q, duplicate one <details> block.
{% endcomment %}

<div class="zk-collection-faq" data-section-id="{{ section.id }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="zk-collection-faq__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="zk-collection-faq__list">
      <details class="zk-collection-faq__item">
        <summary class="zk-collection-faq__summary">
          <span class="zk-collection-faq__question">How do these tees fit?</span>
          <svg class="zk-collection-faq__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <div class="zk-collection-faq__answer">
          <p>Our tees run true to size with a relaxed, straight-cut body — think vintage boxy, not tight. If you want a fitted look, size down one. 5'10" / 170lb wears a Medium. Unsure? Shoot us a note and we'll help you pick.</p>
        </div>
      </details>

      <details class="zk-collection-faq__item">
        <summary class="zk-collection-faq__summary">
          <span class="zk-collection-faq__question">Will the print crack, peel, or fade?</span>
          <svg class="zk-collection-faq__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <div class="zk-collection-faq__answer">
          <p>No. We use soft-hand DTG inks that sink into the fabric instead of sitting on top. The print gets softer with wear and holds color through washes. Wash inside-out in cold water, hang dry, and it'll outlast the tee itself.</p>
        </div>
      </details>

      <details class="zk-collection-faq__item">
        <summary class="zk-collection-faq__summary">
          <span class="zk-collection-faq__question">How long until my order ships?</span>
          <svg class="zk-collection-faq__chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        <div class="zk-collection-faq__answer">
          <p>Orders ship within 1–2 business days — same day if you order before 2pm ET on a weekday. You'll get a tracking email the moment it leaves the studio. Most U.S. orders arrive within 5–7 days total.</p>
        </div>
      </details>
    </div>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__heading {
    font-size: 22px;
    margin: 0 0 18px;
    color: #1a1b2e;
    letter-spacing: 0.01em;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__list {
    max-width: 720px;
    margin: 0 auto;
    border-top: 1px solid rgba(26, 27, 46, 0.1);
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__item {
    border-bottom: 1px solid rgba(26, 27, 46, 0.1);
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 4px;
    cursor: pointer;
    list-style: none;
    color: #1a1b2e;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.005em;
    transition: color 0.15s ease;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__summary::-webkit-details-marker {
    display: none;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__summary:hover {
    color: #555a6e;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__summary:focus-visible {
    outline: 2px solid #1a1b2e;
    outline-offset: 2px;
    border-radius: 4px;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__question {
    flex: 1;
    text-align: left;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__chevron {
    flex-shrink: 0;
    opacity: 0.65;
    transition: transform 0.2s ease;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__item[open] .zk-collection-faq__chevron {
    transform: rotate(180deg);
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__answer {
    padding: 0 4px 20px;
    color: #3a3d50;
    font-size: 14px;
    line-height: 1.6;
    animation: zk-faq-fade 0.25s ease;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__answer p {
    margin: 0 0 10px;
  }

  #shopify-section-{{ section.id }} .zk-collection-faq__answer p:last-child {
    margin-bottom: 0;
  }

  @keyframes zk-faq-fade {
    from { opacity: 0; transform: translateY(-2px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    #shopify-section-{{ section.id }} .zk-collection-faq__heading {
      font-size: 19px;
      margin-bottom: 12px;
    }
    #shopify-section-{{ section.id }} .zk-collection-faq__summary {
      font-size: 14px;
      padding: 16px 4px;
    }
    #shopify-section-{{ section.id }} .zk-collection-faq__answer {
      font-size: 13px;
    }
  }
{%- endstyle -%}

{% schema %}
  {
    "name": "Collection FAQ",
    "settings": [
      {
        "type": "paragraph",
        "content": "3 FAQ items: fit, print durability, shipping. Edit Q&A directly in sections/collection-faq.liquid. To add items, duplicate a <details> block."
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Frequently asked"
      },
      {
        "type": "range",
        "id": "padding_top",
        "label": "Top padding",
        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "default": 48
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "label": "Bottom padding",
        "min": 0,
        "max": 120,
        "step": 4,
        "unit": "px",
        "default": 64
      }
    ]
  }
{% endschema %}
