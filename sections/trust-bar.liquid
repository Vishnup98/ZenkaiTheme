<div class="trust-bar-section">
  <div class="page-width">
    <div class="trust-bar">
      <div class="trust-bar__item">
        <span class="trust-bar__dot" aria-hidden="true"></span>
        <span class="trust-bar__text">Free U.S. shipping</span>
      </div>
      <div class="trust-bar__item">
        <span class="trust-bar__dot trust-bar__dot--two" aria-hidden="true"></span>
        <span class="trust-bar__text">Ships in 1–2 business days</span>
      </div>
      <a href="/pages/policy" class="trust-bar__item trust-bar__item--link">
        <span class="trust-bar__dot trust-bar__dot--three" aria-hidden="true"></span>
        <span class="trust-bar__text">30-day first-item guarantee</span>
      </a>
    </div>
  </div>
</div>

<style>
.trust-bar-section {
  background: #f6f5f0;
  padding: 14px 0;
  margin: 0;
  border-top: 1px solid rgba(26, 27, 46, 0.06);
  border-bottom: 1px solid rgba(26, 27, 46, 0.06);
}

.trust-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
}

.trust-bar__item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 14px;
  border: 1px solid rgba(89, 102, 207, 0.22);
  border-radius: 999px;
  background: rgba(89, 102, 207, 0.08);
  color: #1a1b2e;
  font-size: 13px;
  font-weight: 600;
  line-height: 1.3;
  letter-spacing: 0.01em;
  transition: background 160ms ease, border-color 160ms ease;
}

.trust-bar__item:hover {
  background: rgba(89, 102, 207, 0.14);
  border-color: rgba(89, 102, 207, 0.36);
}

.trust-bar__item--link {
  text-decoration: none;
  cursor: pointer;
}
.trust-bar__item--link:hover {
  text-decoration: none;
}

.trust-bar__dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #5966cf;
  flex-shrink: 0;
  box-shadow: 0 0 0 3px rgba(89, 102, 207, 0.18);
}

.trust-bar__dot--two {
  background: #f59e3c;
  box-shadow: 0 0 0 3px rgba(245, 158, 60, 0.18);
}

.trust-bar__dot--three {
  background: #2aa06a;
  box-shadow: 0 0 0 3px rgba(42, 160, 106, 0.18);
}

.trust-bar__text { color: inherit; }

@media screen and (max-width: 768px) {
  .trust-bar-section { padding: 12px 0; }
  .trust-bar { gap: 8px; }
  .trust-bar__item {
    flex: 1 1 auto;
    padding: 7px 11px;
    font-size: 12px;
    white-space: nowrap;
  }
  .trust-bar__dot { width: 6px; height: 6px; box-shadow: 0 0 0 2px rgba(89, 102, 207, 0.18); }
  .trust-bar__dot--two { box-shadow: 0 0 0 2px rgba(245, 158, 60, 0.18); }
  .trust-bar__dot--three { box-shadow: 0 0 0 2px rgba(42, 160, 106, 0.18); }
}
</style>

