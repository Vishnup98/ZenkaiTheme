<div class="trust-bar-section index-section">
  <div class="page-width">
    <div class="trust-bar">
      <div class="trust-bar__item">
        <span class="trust-bar__text">Free U.S. shipping</span>
      </div>
      <div class="trust-bar__item">
        <span class="trust-bar__text">Shipped in 1-3 business days</span>
      </div>
      <div class="trust-bar__item">
        <span class="trust-bar__text">Secure checkout</span>
      </div>
    </div>
  </div>
</div>

<style>
.trust-bar-section {
  background: #eef0f4;
  padding: 12px 0;
  border-top: 1px solid rgba(26, 27, 46, 0.08);
  border-bottom: 1px solid rgba(26, 27, 46, 0.08);
}

.trust-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 10px;
}

.trust-bar__item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8px 12px;
  border: 1px solid rgba(26, 27, 46, 0.08);
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.72);
  color: #1a1b2e;
  font-size: 13px;
  font-weight: 600;
  line-height: 1.35;
  text-align: center;
}

@media screen and (max-width: 768px) {
  .trust-bar {
    gap: 8px;
  }

  .trust-bar__item {
    flex: 1 1 auto;
    padding: 7px 10px;
    font-size: 12px;
    white-space: nowrap;
  }
}
</style>

