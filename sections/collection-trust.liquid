{% comment %}
  Collection trust row — hardcoded 3 items.
  Rendered after the product grid on collection pages.
  Edit the three trust items directly in this file to change copy.
{% endcomment %}

<div class="zk-collection-trust" data-section-id="{{ section.id }}">
  <div class="page-width">
    <div class="zk-collection-trust__inner">
      <span class="zk-collection-trust__item">
        <svg class="zk-collection-trust__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="1" y="5" width="14" height="12" rx="1"></rect>
          <polygon points="15 8 20 8 23 11.5 23 17 15 17"></polygon>
          <circle cx="5.5" cy="18.5" r="2"></circle>
          <circle cx="18.5" cy="18.5" r="2"></circle>
        </svg>
        <span>Always free U.S. shipping</span>
      </span>
      <span class="zk-collection-trust__dot" aria-hidden="true"></span>
      <span class="zk-collection-trust__item">
        <svg class="zk-collection-trust__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="13 2 4 14 12 14 11 22 20 10 12 10 13 2"></polyline>
        </svg>
        <span>Ships in 1–2 business days</span>
      </span>
      <span class="zk-collection-trust__dot" aria-hidden="true"></span>
      <a href="/pages/policy" class="zk-collection-trust__item zk-collection-trust__item--link">
        <svg class="zk-collection-trust__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="1 4 1 10 7 10"></polyline>
          <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
        </svg>
        <span>30-day first-item guarantee</span>
      </a>
    </div>
  </div>
</div>

{%- style -%}
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #shopify-section-{{ section.id }} .zk-collection-trust__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 10px 20px;
    background: #f6f5f0;
    border: 1px solid rgba(26, 27, 46, 0.09);
    border-radius: 10px;
    padding: 16px 24px;
    color: #1a1b2e;
    font-size: 13px;
    letter-spacing: 0.01em;
  }

  #shopify-section-{{ section.id }} .zk-collection-trust__item {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 500;
  }

  #shopify-section-{{ section.id }} .zk-collection-trust__item--link {
    color: inherit;
    text-decoration: none;
    transition: color 160ms ease;
  }
  #shopify-section-{{ section.id }} .zk-collection-trust__item--link:hover {
    color: #5966cf;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .zk-collection-trust__icon {
    flex-shrink: 0;
    opacity: 0.85;
  }

  #shopify-section-{{ section.id }} .zk-collection-trust__dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(26, 27, 46, 0.3);
  }

  @media (max-width: 640px) {
    #shopify-section-{{ section.id }} .zk-collection-trust__inner {
      gap: 10px 14px;
      padding: 14px 16px;
      font-size: 12px;
    }
    #shopify-section-{{ section.id }} .zk-collection-trust__dot {
      display: none;
    }
    #shopify-section-{{ section.id }} .zk-collection-trust__item {
      flex-basis: 100%;
      justify-content: center;
    }
  }
{%- endstyle -%}

{% schema %}
  {
    "name": "Collection trust row",
    "settings": [
      {
        "type": "paragraph",
        "content": "Three trust items: free shipping, ship time, guarantee (links to /pages/policy). Edit copy directly in sections/collection-trust.liquid."
      },
      {
        "type": "range",
        "id": "padding_top",
        "label": "Top padding",
        "min": 0,
        "max": 80,
        "step": 4,
        "unit": "px",
        "default": 32
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "label": "Bottom padding",
        "min": 0,
        "max": 80,
        "step": 4,
        "unit": "px",
        "default": 16
      }
    ]
  }
{% endschema %}
