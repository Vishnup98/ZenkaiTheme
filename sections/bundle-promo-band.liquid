{%- assign heading = section.settings.heading | default: 'Mix any 2+ styles, save up to $20' -%}
{%- assign subheading = section.settings.subheading -%}
{%- if subheading == blank -%}
  {%- capture subheading -%}{% include 'bundle-tiers', format: 'long' %}{%- endcapture -%}
{%- endif -%}
{%- assign cta_text = section.settings.cta_text | default: 'Shop best-sellers' -%}
{%- assign cta_link = section.settings.cta_link | default: '/collections/best-selling' -%}
{%- assign bg_color = section.settings.bg_color | default: '#1a1b2e' -%}
{%- assign text_color = section.settings.text_color | default: '#ffffff' -%}

<section class="bundle-promo-band" style="background: {{ bg_color }}; color: {{ text_color }};">
  <div class="page-width">
    <div class="bundle-promo-band__inner">
      <span class="bundle-eyebrow bundle-eyebrow--light" aria-hidden="true">
        <span class="bundle-eyebrow__dot"></span>
        <span class="bundle-eyebrow__text">Bundle &amp; save</span>
      </span>
      <h2 class="bundle-promo-band__heading">{{ heading }}</h2>
      <p class="bundle-promo-band__sub">{{ subheading }}</p>

      <ul class="bundle-promo-band__tiers" role="list">
        <li class="bundle-promo-band__tier">
          <span class="bundle-promo-band__tier-num">2</span>
          <span class="bundle-promo-band__tier-save">Save $5</span>
        </li>
        <li class="bundle-promo-band__tier">
          <span class="bundle-promo-band__tier-num">3</span>
          <span class="bundle-promo-band__tier-save">Save $10</span>
        </li>
        <li class="bundle-promo-band__tier bundle-promo-band__tier--accent">
          <span class="bundle-promo-band__tier-num">4+</span>
          <span class="bundle-promo-band__tier-save">Save $20</span>
        </li>
      </ul>

      <p class="bundle-promo-band__mix">Mix any styles — tees, hoodies, hats — all count toward your bundle. Discount auto-applies at checkout.</p>

      <a class="bundle-promo-band__cta" href="{{ cta_link }}" style="background: {{ text_color }}; color: {{ bg_color }};">
        {{ cta_text }}
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .bundle-promo-band { padding: 60px 0; }
  .bundle-promo-band__inner {
    display: flex; flex-direction: column; align-items: center;
    text-align: center; max-width: 720px; margin: 0 auto;
  }
  .bundle-promo-band .bundle-eyebrow { margin-bottom: 16px; }

  /* Defensive: include the eyebrow CSS here in case promo-bar is ever
     removed from the layout. Keeps this section self-contained. */
  .bundle-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.14em;
    text-transform: uppercase; white-space: nowrap; color: #1a1b2e;
  }
  .bundle-eyebrow__dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #5966cf; display: inline-block; flex-shrink: 0;
  }
  .bundle-eyebrow--light { color: #ffffff; }
  .bundle-eyebrow--light .bundle-eyebrow__dot { background: #ffffff; }

  .bundle-promo-band__heading {
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.12; margin: 0 0 14px; color: inherit;
    font-weight: 600; letter-spacing: -0.01em;
  }
  .bundle-promo-band__sub {
    font-size: 15px; line-height: 1.55; opacity: 0.85;
    margin: 0 0 28px; max-width: 540px;
  }
  .bundle-promo-band__tiers {
    display: flex; gap: 14px; flex-wrap: wrap;
    justify-content: center; list-style: none;
    padding: 0; margin: 0 0 18px;
  }
  .bundle-promo-band__tier {
    display: flex; flex-direction: column; align-items: center;
    padding: 14px 22px; border-radius: 10px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.12);
    min-width: 110px;
  }
  .bundle-promo-band__tier--accent {
    background: rgba(89, 102, 207, 0.18);
    border-color: rgba(89, 102, 207, 0.48);
  }
  .bundle-promo-band__tier-num {
    font-size: 28px; font-weight: 600; line-height: 1;
    margin-bottom: 4px;
  }
  .bundle-promo-band__tier-save {
    font-size: 12px; font-weight: 500;
    letter-spacing: 0.04em; opacity: 0.9;
  }
  .bundle-promo-band__mix {
    font-size: 13px;
    line-height: 1.5;
    opacity: 0.75;
    margin: 0 0 28px;
    max-width: 520px;
  }
  .bundle-promo-band__cta {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 28px; border-radius: 999px;
    font-size: 14px; font-weight: 600;
    letter-spacing: 0.04em; text-decoration: none;
    transition: opacity 180ms ease, transform 180ms ease;
  }
  .bundle-promo-band__cta:hover { transform: translateY(-1px); opacity: 0.94; }

  @media (max-width: 640px) {
    .bundle-promo-band { padding: 44px 0; }
    .bundle-promo-band__tier { padding: 10px 16px; min-width: 90px; }
    .bundle-promo-band__tier-num { font-size: 22px; }
    .bundle-promo-band__mix { font-size: 12px; }
  }
</style>

{% schema %}
{
  "name": "Bundle Promo Band",
  "class": "index-section--flush",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Mix any 2+ styles, save up to $20"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "info": "Leave blank to use the default tier copy from bundle-tiers snippet."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Shop best-sellers"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link",
      "info": "Defaults to /collections/best-selling when blank."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1a1b2e"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [{
    "name": "Bundle Promo Band",
    "category": "Promotional"
  }]
}
{% endschema %}
