{% include 'product-template',
  section_id: product.id,

  product_signal_hook: section.settings.product_signal_hook,
  product_social_subheadline: section.settings.product_social_subheadline,
  product_cta_text: section.settings.product_cta_text,
  product_cta_subcopy: section.settings.product_cta_subcopy,
  product_outcome_1: section.settings.product_outcome_1,
  product_outcome_2: section.settings.product_outcome_2,
  product_outcome_3: section.settings.product_outcome_3,
  product_context_heading: section.settings.product_context_heading,
  product_context_1: section.settings.product_context_1,
  product_context_2: section.settings.product_context_2,
  product_context_3: section.settings.product_context_3,
  product_proof_quote_1: section.settings.product_proof_quote_1,
  product_proof_quote_2: section.settings.product_proof_quote_2,
  product_proof_attribution_1: section.settings.product_proof_attribution_1,
  product_proof_attribution_2: section.settings.product_proof_attribution_2,
  product_trust_1: section.settings.product_trust_1,
  product_trust_2: section.settings.product_trust_2,
  product_trust_3: section.settings.product_trust_3,
  hide_mobile_breadcrumbs: section.settings.hide_mobile_breadcrumbs,
  product_mobile_media_max_height: section.settings.product_mobile_media_max_height,
  product_sticky_atc_trigger_ratio: section.settings.product_sticky_atc_trigger_ratio,
  product_show_review_summary_first: section.settings.product_show_review_summary_first,
  product_image_size: section.settings.product_image_size,
  product_image_type: section.settings.product_image_type,
  product_zoom_enable: section.settings.product_zoom_enable,
  variant_type: section.settings.variant_type,
  variant_labels_enable: section.settings.variant_labels_enable,
  sku_enable: section.settings.sku_enable,
  quantity_enable: section.settings.quantity_enable,
  inventory_enable: section.settings.inventory_enable,
  inventory_threshold: section.settings.inventory_threshold,
  inventory_transfers_enable: section.settings.inventory_transfers_enable,
  enable_payment_button: section.settings.enable_payment_button,
  mobile_sticky_atc_enable: section.settings.mobile_sticky_atc_enable,
  show_dynamic_checkout_secondary: section.settings.show_dynamic_checkout_secondary,
  social_enable: section.settings.social_enable,
  video_looping: section.settings.enable_video_looping,
  video_style: section.settings.product_video_style
%}


<script>
  theme.productStrings = {
    addToCart: {{ 'products.product.add_to_cart' | t | json }},
    soldOut: {{ 'products.product.sold_out' | t | json }},
    unavailable: {{ 'products.product.unavailable' | t | json }}
  };

  var ctaOverride = document.querySelector('[data-product-cta-default]');
  if (ctaOverride) {
    theme.productStrings.addToCart = ctaOverride.getAttribute('data-product-cta-default');
  }
</script>

{% if settings.enable_product_reviews %}
  <div id="Reviews-{{ product.id }}" class="index-section product-reviews product-reviews--full">
    <div class="page-width">
      <div id="shopify-product-reviews" data-id="{{product.id}}">{{ product.metafields.spr.reviews }}</div>
    </div>
  </div>
{% endif %}

{% schema %}
  {
    "name": "Product pages",
    "blocks": [
      {
        "type": "@app"
      }
    ],
    "settings": [
      {
        "type": "header",
        "content": "Media"
      },
      {
        "type": "select",
        "id": "product_image_size",
        "label": "Image size",
        "default": "large",
        "options": [
          {
            "value": "small",
            "label": "Small"
          },
          {
            "value": "medium",
            "label": "Medium"
          },
          {
            "value": "large",
            "label": "Large"
          }
        ]
      },
      {
        "type": "select",
        "id": "product_image_type",
        "label": "Image style",
        "default": "stacked",
        "options": [
          {
            "value": "stacked",
            "label": "Stacked"
          },
          {
            "value": "slider",
            "label": "Fade"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "product_zoom_enable",
        "label": "Enable image zoom",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_video_looping",
        "label": "Enable video looping",
        "default": true
      },
      {
        "type": "select",
        "id": "product_video_style",
        "label": "Video style",
        "default": "muted",
        "options": [
          {
            "value": "muted",
            "label": "Video without sound"
          },
          {
            "value": "unmuted",
            "label": "Video with sound"
          }
        ],
        "info": "Video with sound will not autoplay"
      },
      {
        "type": "header",
        "content": "Product settings"
      },
      {
        "type": "checkbox",
        "id": "enable_payment_button",
        "label": "Show dynamic checkout button",
        "info": "Lets customers check out directly using a familiar payment method. [Learn more](https://help.shopify.com/manual/using-themes/change-the-layout/dynamic-checkout)",
        "default": true
      },
      {
        "type": "text",
        "id": "product_signal_hook",
        "label": "Signal hook",
        "default": "The ones who get it, get it."
      },
      {
        "type": "textarea",
        "id": "product_social_subheadline",
        "label": "Social outcome subheadline",
        "default": "A subtle reference that gets noticed by the right people."
      },
      {
        "type": "text",
        "id": "product_cta_text",
        "label": "Primary CTA text",
        "default": "Add to Cart"
      },
      {
        "type": "text",
        "id": "product_cta_subcopy",
        "label": "CTA subcopy",
        "default": "Free U.S. shipping. Printed to order."
      },
      {
        "type": "text",
        "id": "product_outcome_1",
        "label": "Outcome 1",
        "default": "The right people notice immediately"
      },
      {
        "type": "text",
        "id": "product_outcome_2",
        "label": "Outcome 2",
        "default": "Subtle enough for everyday wear"
      },
      {
        "type": "text",
        "id": "product_outcome_3",
        "label": "Outcome 3",
        "default": "The kind of shirt that starts conversations at the right events"
      },
      {
        "type": "text",
        "id": "product_context_heading",
        "label": "Context section heading",
        "default": "Where this hits"
      },
      {
        "type": "text",
        "id": "product_context_1",
        "label": "Context 1",
        "default": "At card shows, the right people catch it fast"
      },
      {
        "type": "text",
        "id": "product_context_2",
        "label": "Context 2",
        "default": "At conventions, it reads clean before it reads fandom"
      },
      {
        "type": "text",
        "id": "product_context_3",
        "label": "Context 3",
        "default": "Day to day, it still just looks good"
      },
      {
        "type": "textarea",
        "id": "product_proof_quote_1",
        "label": "Proof quote 1",
        "default": "Wore it out and someone caught the reference almost immediately."
      },
      {
        "type": "text",
        "id": "product_proof_attribution_1",
        "label": "Proof attribution 1",
        "default": "Recent buyer"
      },
      {
        "type": "textarea",
        "id": "product_proof_quote_2",
        "label": "Proof quote 2",
        "default": "Exactly the kind of subtle design I wanted. It gets noticed by the right people."
      },
      {
        "type": "text",
        "id": "product_proof_attribution_2",
        "label": "Proof attribution 2",
        "default": "Show floor regular"
      },
      {
        "type": "header",
        "content": "Trust strip"
      },
      {
        "type": "text",
        "id": "product_trust_1",
        "label": "Trust bullet 1",
        "default": "Free U.S. shipping on every order"
      },
      {
        "type": "text",
        "id": "product_trust_2",
        "label": "Trust bullet 2",
        "default": "1,900+ orders shipped and counting"
      },
      {
        "type": "text",
        "id": "product_trust_3",
        "label": "Trust bullet 3",
        "default": "Premium ring-spun cotton · Not thin, not boxy"
      },
      {
        "type": "checkbox",
        "id": "hide_mobile_breadcrumbs",
        "label": "Hide breadcrumbs on mobile",
        "default": true
      },
      {
        "type": "range",
        "id": "product_mobile_media_max_height",
        "label": "Mobile media max height",
        "default": 54,
        "min": 50,
        "max": 80,
        "step": 2,
        "unit": "vh"
      },
      {
        "type": "range",
        "id": "product_sticky_atc_trigger_ratio",
        "label": "Sticky CTA trigger",
        "default": 18,
        "min": 5,
        "max": 40,
        "step": 1,
        "unit": "%"
      },
      {
        "type": "checkbox",
        "id": "product_show_review_summary_first",
        "label": "Prefer review summary in hero",
        "default": true
      },
      {
        "type": "select",
        "id": "variant_type",
        "label": "Variant picker style",
        "default": "button",
        "options": [
          {
            "value": "button",
            "label": "Buttons"
          },
          {
            "value": "dropdown",
            "label": "Dropdown"
          }
        ]
      },
      {
        "type": "checkbox",
        "id": "variant_labels_enable",
        "label": "Show variant labels",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "sku_enable",
        "label": "Show SKU"
      },
      {
        "type": "checkbox",
        "id": "inventory_enable",
        "label": "Show inventory notice"
      },
      {
        "type": "range",
        "id": "inventory_threshold",
        "label": "Inventory threshold",
        "default": 10,
        "min": 0,
        "max": 20,
        "step": 2
      },
      {
        "type": "checkbox",
        "id": "inventory_transfers_enable",
        "label": "Show inventory transfer notice",
        "info": "Learn how to create inventory transfers [here](https://help.shopify.com/en/manual/products/inventory/transfers/create-transfer)"
      },
      {
        "type": "checkbox",
        "id": "quantity_enable",
        "label": "Show quantity field"
      },
      {
        "type": "checkbox",
        "id": "mobile_sticky_atc_enable",
        "label": "Enable mobile sticky add-to-cart",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_dynamic_checkout_secondary",
        "label": "Show dynamic checkout as a secondary button",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "social_enable",
        "label": "Show share links on product page",
        "default": false
      }
    ]
  }
{% endschema %}