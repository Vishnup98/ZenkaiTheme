<div class="collection-search" style="margin: 2rem 0; text-align: center;">
  <p style="font-size: 1.2rem; margin-bottom: 1rem;">Search by name or number</p>
  <form action="/search" method="get" role="search" style="display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap;">
    <input type="hidden" name="type" value="product">
    <input type="hidden" name="constraint" value="{{ collection.handle }}">
    <input
      type="search"
      name="q"
      placeholder="Try a name, number, or style..."
      style="padding: 0.75rem 1rem; flex: 1 1 0%; min-width: 0; max-width: 400px; font-size: 1rem; border: 1px solid rgba(26, 27, 46, 0.12); border-radius: 9999px; background: #fff;"
    >
    <button type="submit" style="min-height: 44px; padding: 0.85rem 1.5rem; font-size: 1rem; background: #1a1b2e; color: #FFFFFF; border: none; border-radius: 9999px; cursor: pointer;">
      Search
    </button>
  </form>
</div>
