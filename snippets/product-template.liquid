{% include 'product-template-variables' %}

{%- assign zenkai_signal_hook = product_signal_hook | default: 'The ones who get it, get it.' -%}
{%- assign zenkai_social_subheadline = product_social_subheadline | default: 'Premium cotton tee with a reference only the real ones catch.' -%}
{%- assign zenkai_cta_text = product_cta_text | default: 'Add to Cart' -%}
{%- assign zenkai_cta_subcopy = product_cta_subcopy | default: 'Free U.S. shipping. Printed to order.' -%}
{%- assign zenkai_outcome_1 = product_outcome_1 | default: 'Heavyweight cotton — not your average print tee' -%}
{%- assign zenkai_outcome_2 = product_outcome_2 | default: 'Subtle enough to wear anywhere, specific enough to get recognized' -%}
{%- assign zenkai_outcome_3 = product_outcome_3 | default: 'Made to order in the USA — just for you' -%}
{%- assign zenkai_context_heading = product_context_heading | default: 'Where this hits' -%}
{%- assign zenkai_context_1 = product_context_1 | default: 'At card shows, the right people catch it fast' -%}
{%- assign zenkai_context_2 = product_context_2 | default: 'At conventions, it reads clean before it reads fandom' -%}
{%- assign zenkai_context_3 = product_context_3 | default: 'Day to day, it still just looks good' -%}
{%- assign zenkai_proof_quote_1 = product_proof_quote_1 | default: 'Wore it out and someone caught the reference almost immediately.' -%}
{%- assign zenkai_proof_attribution_1 = product_proof_attribution_1 | default: 'Recent buyer' -%}
{%- assign zenkai_proof_quote_2 = product_proof_quote_2 | default: 'Clean enough to wear to the office, but the right people still catch it every time. Exactly what I wanted.' -%}
{%- assign zenkai_proof_attribution_2 = product_proof_attribution_2 | default: 'Show floor regular' -%}
{%- assign zenkai_current_variant_label = current_variant.title -%}
{%- assign zenkai_mobile_sticky_atc = true -%}
{%- assign zenkai_secondary_checkout = true -%}
{%- assign zenkai_hide_mobile_breadcrumbs = true -%}
{%- assign zenkai_mobile_media_max_height = product_mobile_media_max_height | default: 52 | plus: 0 -%}
{%- assign zenkai_sticky_atc_trigger_ratio = product_sticky_atc_trigger_ratio | default: 18 | plus: 0 -%}
{%- assign zenkai_primary_proof_quote = zenkai_proof_quote_1 -%}
{%- assign zenkai_primary_proof_attribution = zenkai_proof_attribution_1 -%}
{%- assign zenkai_show_social_proof_panel = false -%}

{% if product.has_only_default_variant or zenkai_current_variant_label == 'Default Title' %}
  {%- assign zenkai_current_variant_label = 'Ready to order' -%}
{% endif %}

{% if mobile_sticky_atc_enable == false %}
  {%- assign zenkai_mobile_sticky_atc = false -%}
{% endif %}

{% if hide_mobile_breadcrumbs == false %}
  {%- assign zenkai_hide_mobile_breadcrumbs = false -%}
{% endif %}

{% if show_dynamic_checkout_secondary %}
  {%- assign zenkai_secondary_checkout = true -%}
{% endif %}


{% if zenkai_primary_proof_quote == blank and zenkai_proof_quote_2 != blank %}
  {%- assign zenkai_primary_proof_quote = zenkai_proof_quote_2 -%}
  {%- assign zenkai_primary_proof_attribution = zenkai_proof_attribution_2 -%}
{% endif %}

{% if zenkai_primary_proof_quote != blank %}
  {%- assign zenkai_show_social_proof_panel = true -%}
{% endif %}

<style>
  #ProductSection-{{ section_id }} {
    --zenkai-page-bg: #f5f5f7;
    --zenkai-surface: #ffffff;
    --zenkai-surface-alt: #eef0f4;
    --zenkai-ink: #1a1b2e;
    --zenkai-muted: #6b6f85;
    --zenkai-dark: #1a1b2e;
    --zenkai-dark-hover: #131428;
    --zenkai-accent: #5966cf;
    --zenkai-accent-soft: #e8eaf8;
    --zenkai-border: rgba(26, 27, 46, 0.1);
  }

  #ProductSection-{{ section_id }} .page-content {
    padding-top: 10px;
    padding-bottom: 0;
    background: var(--zenkai-page-bg);
  }

  #ProductSection-{{ section_id }} .page-width {
    position: relative;
  }

  #ProductSection-{{ section_id }} .product-single__meta {
    padding-left: 36px;
  }

  #ProductSection-{{ section_id }} .product-single__sticky {
    top: 28px;
  }

  .zenkai-breadcrumb {
    margin-bottom: 0.85rem;
  }

  .zenkai-breadcrumb__list {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    padding: 0;
    list-style: none;
    color: var(--zenkai-muted);
    font-size: 0.8rem;
    line-height: 1.2;
  }

  .zenkai-breadcrumb__link {
    color: var(--zenkai-muted);
    text-decoration: none;
  }

  .zenkai-breadcrumb__link:hover,
  .zenkai-breadcrumb__link:focus {
    color: var(--zenkai-ink);
  }

  .zenkai-breadcrumb__link:focus-visible {
    outline: 2px solid var(--zenkai-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .zenkai-breadcrumb--mobile-hidden {
    display: block;
  }

  #ProductSection-{{ section_id }} .product__main-photos-wrapper {
    border: 1px solid var(--zenkai-border);
    border-radius: 18px;
    background: var(--zenkai-surface);
    overflow: hidden;
    box-shadow: 0 18px 36px rgba(26, 27, 46, 0.06);
  }

  #ProductSection-{{ section_id }} .product__photo-dots {
    margin-top: 0.4rem;
  }

  #ProductSection-{{ section_id }} .product__thumbs .product__thumb {
    border-radius: 14px;
    overflow: hidden;
    background: var(--zenkai-surface);
  }

  .zenkai-zoom-hint {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    background: rgba(26, 27, 46, 0.8);
    color: #fff;
    font-size: 0.75rem;
    line-height: 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  #ProductSection-{{ section_id }} .product__main-photos:hover .zenkai-zoom-hint {
    opacity: 1;
  }

  #ProductSection-{{ section_id }} .product-single__header {
    margin-bottom: 0;
    padding: 1.1rem;
    border: 1px solid var(--zenkai-border);
    border-radius: 18px;
    background: var(--zenkai-surface);
    box-shadow: 0 14px 30px rgba(26, 27, 46, 0.05);
  }

  .zenkai-signal-hook {
    margin: 0 0 0.55rem;
    color: var(--zenkai-accent);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.01em;
  }

  #ProductSection-{{ section_id }} .product-single__title {
    margin-bottom: 0.55rem !important;
    color: var(--zenkai-ink);
    font-size: 2.35rem !important;
    font-weight: 800;
    line-height: 1.05 !important;
    letter-spacing: -0.03em;
  }

  .zenkai-social-subheadline {
    margin: 0;
    color: var(--zenkai-ink);
    font-size: 1.03rem;
    line-height: 1.45;
  }

  .zenkai-hero-proof-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.95rem;
  }

  .zenkai-hero-proof-copy {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin: 0;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: var(--zenkai-accent-soft);
    color: var(--zenkai-ink);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .zenkai-price-band {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.75rem;
    margin-top: 1rem;
    padding: 0.8rem 0.95rem;
    border-radius: 16px;
    background: var(--zenkai-surface-alt);
    border: 1px solid rgba(89, 102, 207, 0.12);
  }

  #ProductSection-{{ section_id }} .product-single__prices {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.65rem;
    margin: 0;
  }

  #ProductSection-{{ section_id }} .product-single__prices .product__price--compare {
    position: relative;
    padding-right: 0;
    color: rgba(26, 27, 46, 0.88);
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
  }

  #ProductSection-{{ section_id }} .product-single__prices .product__price--compare::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    background: rgba(26, 27, 46, 0.65);
    transform: translateY(-50%);
  }

  #ProductSection-{{ section_id }} .product-single__prices .product__price {
    padding-right: 0;
    color: var(--zenkai-ink);
    font-size: 1.9rem;
    font-weight: 800;
    line-height: 1;
  }

  #ProductSection-{{ section_id }} .product-single__prices .product__price.sale-price {
    color: var(--zenkai-accent);
  }

  #ProductSection-{{ section_id }} .product-single__prices .you-save {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    background: var(--zenkai-accent);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 700;
    line-height: 1.2;
    box-shadow: 0 3px 12px -1px rgba(89, 102, 207, 0.4);
  }

  .zenkai-conversion-stack {
    margin-top: 1rem;
  }

  #ProductSection-{{ section_id }} .product-single__form {
    margin: 0;
    padding: 1.1rem;
    border: 1px solid var(--zenkai-border);
    border-radius: 18px;
    background: var(--zenkai-surface);
    box-shadow: 0 14px 30px rgba(26, 27, 46, 0.04);
  }

  #ProductSection-{{ section_id }} .variant-wrapper {
    margin-bottom: 1rem;
    text-align: left;
  }

  #ProductSection-{{ section_id }} .variant-wrapper:last-of-type {
    margin-bottom: 0.85rem;
  }

  #ProductSection-{{ section_id }} .variant__label {
    display: block;
    margin: 0 0 0.4rem;
    color: var(--zenkai-ink);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
  }

  #ProductSection-{{ section_id }} .variant__label-info {
    color: var(--zenkai-muted);
    font-weight: 500;
  }

  #ProductSection-{{ section_id }} .variant__label-note {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    margin: 0 0 0.55rem;
    padding: 0.5rem 0;
    border: 0;
    background: none;
    color: var(--zenkai-muted);
    font-size: 0.85rem;
    font-weight: 600;
    line-height: 1.35;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.15em;
    cursor: pointer;
  }

  #ProductSection-{{ section_id }} .variant__label-note:hover,
  #ProductSection-{{ section_id }} .variant__label-note:focus {
    color: var(--zenkai-ink);
  }

  #ProductSection-{{ section_id }} .variant-input-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin: 0;
  }

  #ProductSection-{{ section_id }} .variant-input {
    margin: 0;
  }

  #ProductSection-{{ section_id }} .variant-input input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }

  #ProductSection-{{ section_id }} .variant-input label {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 3.1rem;
    min-height: 2.95rem;
    padding: 0.75rem 0.9rem;
    border: 1px solid rgba(26, 27, 46, 0.14);
    border-radius: 10px;
    background: var(--zenkai-surface-alt);
    color: var(--zenkai-ink);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1;
    cursor: pointer;
    transition: border-color 0.18s ease, background-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  #ProductSection-{{ section_id }} .variant-input input:checked + label {
    border-color: var(--zenkai-dark);
    background: var(--zenkai-dark);
    color: #fff;
    box-shadow: 0 10px 22px rgba(26, 27, 46, 0.14);
  }

  #ProductSection-{{ section_id }} .variant-input label:hover,
  #ProductSection-{{ section_id }} .variant-input label:focus {
    transform: translateY(-1px);
    border-color: rgba(26, 27, 46, 0.28);
  }

  #ProductSection-{{ section_id }} .variant-input label:active {
    transform: scale(0.96);
    border-color: rgba(26, 27, 46, 0.28);
  }

  #ProductSection-{{ section_id }} .variant-input label:focus-visible,
  #ProductSection-{{ section_id }} .variant-input input:focus-visible + label {
    outline: 2px solid var(--zenkai-accent);
    outline-offset: 2px;
  }

  #ProductSection-{{ section_id }} .variant-input label.disabled,
  #ProductSection-{{ section_id }} .variant-input .color-swatch.disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  #ProductSection-{{ section_id }} .color-swatch {
    min-width: 2.95rem;
    min-height: 2.95rem;
    border-radius: 999px;
    background-size: cover;
    background-position: center;
    transition: box-shadow 0.18s ease, transform 0.18s ease;
  }

  #ProductSection-{{ section_id }} .variant-input input:checked + .color-swatch {
    box-shadow: 0 0 0 2px var(--zenkai-surface), 0 0 0 4px var(--zenkai-dark);
  }

  #ProductSection-{{ section_id }} .variant-input input:focus-visible + .color-swatch {
    outline: 2px solid var(--zenkai-accent);
    outline-offset: 4px;
  }

  .zenkai-product-actions {
    margin-top: 0.4rem;
  }

  #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta {
    position: relative;
    overflow: hidden;
    width: 100%;
    min-height: 58px;
    border: 0;
    border-radius: 12px;
    background: var(--zenkai-accent) !important;
    color: #fff !important;
    font-size: 1rem;
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: 0.01em;
    text-transform: none;
    box-shadow: 0 18px 30px rgba(89, 102, 207, 0.22), 0 6px 20px -2px rgba(89, 102, 207, 0.4);
    transition: transform 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
  }

  #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta:hover,
  #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta:focus {
    background: #4e5abf !important;
    box-shadow: 0 20px 32px rgba(89, 102, 207, 0.28), 0 8px 24px -2px rgba(89, 102, 207, 0.45);
    transform: translateY(-1px);
  }

  #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta:active {
    transform: scale(0.98);
    box-shadow: 0 8px 18px rgba(89, 102, 207, 0.18);
  }

  #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta:disabled {
    background: rgba(89, 102, 207, 0.35) !important;
    color: rgba(255, 255, 255, 0.7) !important;
    box-shadow: none;
    transform: none;
  }

  #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta:focus-visible {
    outline: 2px solid var(--zenkai-accent);
    outline-offset: 2px;
  }

  #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.08) 45%,
      rgba(255, 255, 255, 0.14) 50%,
      rgba(255, 255, 255, 0.08) 55%,
      transparent 60%
    );
    background-size: 200% 100%;
    animation: zenkai-shimmer 8s ease-in-out infinite;
    pointer-events: none;
    border-radius: inherit;
  }

  #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta:disabled::after {
    animation: none;
    opacity: 0;
  }

  @keyframes zenkai-shimmer {
    0%, 75% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta::after {
      animation: none;
    }
  }

  .zenkai-trust-strip {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.4rem 1.1rem;
    margin: 0 0 0.7rem;
  }

  .zenkai-trust-item {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--zenkai-muted);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .zenkai-trust-item svg {
    flex: 0 0 auto;
    color: var(--zenkai-accent);
  }

  .zenkai-fit-note {
    margin: 0 0 0.45rem;
    color: var(--zenkai-muted);
    font-size: 0.82rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .zenkai-sticky-atc__trust {
    display: block;
    margin-top: 0.08rem;
    color: rgba(255, 255, 255, 0.48);
    font-size: 0.68rem;
    font-weight: 500;
    line-height: 1.2;
  }

  .zenkai-secondary-checkout {
    margin-top: 0.75rem;
  }

  .zenkai-secondary-checkout .shopify-payment-button__button {
    border-radius: 12px !important;
    min-height: 54px !important;
  }

  .zenkai-outcome-panel,
  .zenkai-context-panel,
  .zenkai-social-proof {
    margin-top: 0.95rem;
    padding: 1.05rem 1.1rem;
    border-radius: 18px;
    border: 1px solid var(--zenkai-border);
    background: var(--zenkai-surface);
  }

  .zenkai-outcome-panel {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98) 0%, rgba(238, 240, 244, 0.9) 100%);
  }

  .zenkai-panel-heading {
    margin: 0 0 0.65rem;
    color: var(--zenkai-ink);
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.2;
  }

  .zenkai-outcome-list,
  .zenkai-context-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .zenkai-outcome-list li,
  .zenkai-context-list li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.65rem;
    color: var(--zenkai-ink);
    font-size: 0.94rem;
    line-height: 1.5;
  }

  .zenkai-outcome-list li:last-child,
  .zenkai-context-list li:last-child {
    margin-bottom: 0;
  }

  .zenkai-outcome-list li::before,
  .zenkai-context-list li::before {
    content: "";
    position: absolute;
    top: 0.48rem;
    left: 0;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--zenkai-accent);
    box-shadow: 0 0 0 4px rgba(89, 102, 207, 0.12);
  }

  .zenkai-context-panel {
    background: var(--zenkai-surface-alt);
    border-color: rgba(89, 102, 207, 0.14);
  }

  .zenkai-context-panel .zenkai-panel-heading {
    display: inline-flex;
    margin-bottom: 0.8rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    color: var(--zenkai-ink);
    font-size: 0.88rem;
    font-weight: 800;
    letter-spacing: 0.04em;
  }

  .zenkai-social-proof {
    background: var(--zenkai-surface);
  }

  .zenkai-social-proof-grid {
    display: block;
  }

  .zenkai-proof-card {
    padding: 0.9rem;
    border-radius: 16px;
    background: var(--zenkai-surface-alt);
    border: 1px solid rgba(89, 102, 207, 0.12);
  }

  .zenkai-proof-card__quote {
    margin: 0;
    color: var(--zenkai-ink);
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.45;
  }

  .zenkai-proof-card__meta {
    display: block;
    margin-top: 0.55rem;
    color: var(--zenkai-muted);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .zenkai-brand-quote {
    margin-top: 0.95rem;
    padding: 1.05rem 1.1rem 1.05rem 1.25rem;
    border-radius: 18px;
    border: 1px solid var(--zenkai-border);
    border-left: 3px solid var(--zenkai-accent);
    background: var(--zenkai-surface);
  }

  .zenkai-brand-quote__text {
    margin: 0;
    color: var(--zenkai-ink);
    font-size: 0.96rem;
    font-weight: 600;
    font-style: italic;
    line-height: 1.5;
  }

  .zenkai-brand-quote__follow {
    margin: 0.5rem 0 0;
    color: var(--zenkai-muted);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .zenkai-additional-content {
    margin-top: 1rem;
  }

  .zenkai-sticky-sentinel {
    width: 100%;
    height: 1px;
    margin-top: 0;
  }

  #ProductSection-{{ section_id }} .product__policies small {
    display: none !important;
  }

  .zenkai-sticky-atc[hidden] {
    display: none !important;
  }

  .zenkai-sticky-atc {
    position: fixed;
    right: 12px;
    left: 12px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 12px);
    z-index: 40;
    display: none;
    align-items: center;
    gap: 0.55rem;
    padding: 0.75rem 0.85rem;
    border-radius: 16px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(26, 27, 46, 0.94);
    box-shadow: 0 20px 36px rgba(0, 0, 0, 0.24);
  }

  .zenkai-sticky-atc.is-visible {
    display: flex;
  }

  .zenkai-sticky-atc__meta {
    flex: 1 1 auto;
    min-width: 0;
  }

  .zenkai-sticky-atc__price {
    display: block;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .zenkai-sticky-atc__variant {
    display: block;
    margin-top: 0.12rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.25;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .zenkai-sticky-atc__button {
    flex: 0 0 auto;
    min-width: 118px;
    min-height: 48px;
    border: 0;
    border-radius: 12px;
    background: var(--zenkai-accent);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    text-transform: none;
    transition: background-color 0.18s ease, transform 0.18s ease;
  }

  .zenkai-sticky-atc__button:hover,
  .zenkai-sticky-atc__button:focus-visible {
    background: #4e5abf;
    outline: 2px solid #fff;
    outline-offset: -2px;
  }

  .zenkai-sticky-atc__button:active {
    transform: scale(0.97);
    background: #4e5abf;
  }

  .zenkai-sticky-atc__button:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  @media (max-width: 767px) {
    #ProductSection-{{ section_id }} .product-single__meta {
      padding-left: 0;
      margin-top: 0.55rem;
    }

    #ProductSection-{{ section_id }} .page-content {
      padding-top: 0;
      padding-bottom: 112px;
    }

    .site-footer {
      padding-bottom: 112px;
    }

    .zenkai-breadcrumb {
      margin-bottom: 0.35rem;
    }

    {% if zenkai_hide_mobile_breadcrumbs %}
      .zenkai-breadcrumb--mobile-hidden {
        display: none;
      }
    {% endif %}

    #ProductSection-{{ section_id }} .product__main-photos-wrapper {
      border-radius: 0;
      border-left: 0;
      border-right: 0;
      box-shadow: none;
    }

    #ProductSection-{{ section_id }} .product__main-photos .product-image-main .image-wrap {
      padding-bottom: min(115%, {{ zenkai_mobile_media_max_height }}vh) !important;
    }

    #ProductSection-{{ section_id }} .product__photo-dots {
      margin-top: 0.2rem;
    }

    #ProductSection-{{ section_id }} .product-single__header,
    #ProductSection-{{ section_id }} .product-single__form,
    .zenkai-outcome-panel,
    .zenkai-context-panel,
    .zenkai-social-proof {
      padding: 0.9rem;
      border-radius: 16px;
      box-shadow: none;
    }

    .zenkai-signal-hook {
      font-size: 0.78rem;
      margin-bottom: 0.45rem;
    }

    #ProductSection-{{ section_id }} .product-single__title {
      font-size: 1.85rem !important;
    }

    .zenkai-social-subheadline {
      font-size: 0.96rem;
    }

    #ProductSection-{{ section_id }} .product-single__prices .product__price {
      font-size: 1.62rem;
    }

    #ProductSection-{{ section_id }} .product-single__prices .product__price--compare {
      font-size: 0.88rem;
    }

    #ProductSection-{{ section_id }} .variant__label,
    .zenkai-panel-heading {
      font-size: 0.9rem;
    }

    .zenkai-context-panel .zenkai-panel-heading {
      font-size: 0.85rem;
    }

    #ProductSection-{{ section_id }} .variant-input label {
      min-width: 2.85rem;
      min-height: 2.75rem;
      padding: 0.7rem 0.85rem;
      font-size: 0.9rem;
    }

    #ProductSection-{{ section_id }} button.add-to-cart.zenkai-primary-cta {
      min-height: 54px;
      font-size: 0.96rem;
    }

    .zenkai-brand-quote {
      padding: 0.9rem 0.9rem 0.9rem 1.1rem;
      border-radius: 16px;
    }

    .zenkai-brand-quote__text {
      font-size: 0.9rem;
    }

    .zenkai-brand-quote__follow {
      font-size: 0.82rem;
    }

    .zenkai-cta-subcopy {
      font-size: 0.84rem;
    }

    .zenkai-outcome-list li,
    .zenkai-context-list li,
    .zenkai-proof-card__quote {
      font-size: 0.88rem;
    }

    .zenkai-proof-card {
      padding: 0.82rem;
    }
  }

  @media (min-width: 768px) {
    .zenkai-sticky-atc {
      display: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #ProductSection-{{ section_id }} *,
    #ProductSection-{{ section_id }} *::before,
    #ProductSection-{{ section_id }} *::after {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
    }
  }
</style>

<div
  id="ProductSection-{{ section_id }}"
  class="product-section"
  data-section-id="{{ section_id }}"
  data-section-type="product-template"
  data-product-cta-default="{{ zenkai_cta_text | escape }}"
  data-sticky-trigger-ratio="{{ zenkai_sticky_atc_trigger_ratio }}"
  {% if isModal %}data-subsection{% endif %}
  data-variant-type="{{ variant_type }}"
  {% if inventory_enable %}data-inventory="true" data-inventory-threshold="{{ inventory_threshold }}"{% endif %}
  {% if inventory_transfers_enable %}data-incoming-inventory="true"{% endif %}
  {% if product_image_type == 'stacked' %}data-images-stacked="true"{% endif %}
  data-video-style="{{ video_style }}"
  {% unless isModal %}data-enable-history-state="true"{% endunless %}
>
  <div class="page-content">
    <div class="page-width">
      <nav aria-label="breadcrumb" class="zenkai-breadcrumb{% if zenkai_hide_mobile_breadcrumbs %} zenkai-breadcrumb--mobile-hidden{% endif %}">
        <ol class="zenkai-breadcrumb__list">
          <li>
            <a href="/" class="zenkai-breadcrumb__link">Home</a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <a href="/collections/all" class="zenkai-breadcrumb__link">All products</a>
          </li>
          <li aria-hidden="true">/</li>
          <li>{{ product.title | truncate: 34 }}</li>
        </ol>
      </nav>

      <div class="grid">
        <div class="grid__item {{ product_image_width }}">
          {% include 'product-images',
            section_id: section_id,
            isModal: isModal,
            video_looping: video_looping,
            video_style: video_style
          %}

          <button type="button" class="zenkai-zoom-hint" aria-label="Zoom image">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
              <line x1="11" y1="8" x2="11" y2="14"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
            </svg>
            Zoom
          </button>
        </div>

        <div class="grid__item {{ product_description_width }}{% if product_image_type == 'stacked' %} product-single__sticky{% endif %}">
          <div class="product-single__meta">
            <div class="product-single__header small--text-center">
              {% if settings.vendor_enable %}
                <div class="product-single__vendor">{{ product.vendor }}</div>
              {% endif %}

              <p class="zenkai-signal-hook">{{ zenkai_signal_hook }}</p>

              {% if isModal %}
                <p class="h2 product-single__title">{{ product.title }}</p>
              {% else %}
                <h1 class="h2 product-single__title">{{ product.title }}</h1>
              {% endif %}

              <p class="zenkai-social-subheadline">{{ zenkai_social_subheadline }}</p>

              <div class="zenkai-price-band">
                <div class="product-single__prices" data-price-wrapper>
                  {% if current_variant.compare_at_price > current_variant.price %}
                    <span class="product__price product__price--compare" data-product-price-compare>
                      {{ current_variant.compare_at_price | money }}
                    </span>
                  {% endif %}

                  <span class="product__price{% if current_variant.compare_at_price > current_variant.price %} sale-price{% endif %}" data-product-price>
                    {{ current_variant.price | money }}
                  </span>

                  {% if current_variant.compare_at_price > current_variant.price %}
                    <span class="you-save">
                      Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
                    </span>
                  {% endif %}
                </div>
              </div>
            </div>

            <div class="zenkai-conversion-stack">
              <section class="zenkai-outcome-panel" aria-label="What you get">
                <h2 class="zenkai-panel-heading">What you get</h2>
                <ul class="zenkai-outcome-list" role="list">
                  <li>{{ zenkai_outcome_1 }}</li>
                  <li>{{ zenkai_outcome_2 }}</li>
                  <li>{{ zenkai_outcome_3 }}</li>
                </ul>
              </section>

              {% unless isModal %}
                {% include 'product-form',
                  section_id: section_id,
                  variant_type: variant_type,
                  variant_labels_enable: variant_labels_enable,
                  quantity_enable: quantity_enable,
                  enable_payment_button: enable_payment_button,
                  product_cta_text: zenkai_cta_text,
                  product_cta_note: zenkai_cta_subcopy,
                  product_cta_subcopy: zenkai_cta_subcopy,
                  show_dynamic_checkout_secondary: zenkai_secondary_checkout
                %}
              {% else %}
                <div id="ProductFormPlaceholder-{{ section_id }}" data-url="{{ product.url | within: collection }}" data-template="{{ product.template_suffix }}" class="product-form-holder">
                  {% if product.options.size > 0 %}
                    {% for i in (1..product.options.size) %}
                      <div class="placeholder-content" style="min-height: 78px; max-width: 66%;"></div>
                    {% endfor %}
                  {% endif %}
                  <div class="placeholder-content" style="min-height: 78px;"></div>
                </div>
              {% endunless %}

              <div class="zenkai-sticky-sentinel" data-sticky-sentinel aria-hidden="true"></div>

              <aside class="zenkai-brand-quote" aria-label="Brand story">
                <p class="zenkai-brand-quote__text">You outgrew the loud prints, but you never outgrew the world that shaped you.</p>
                <p class="zenkai-brand-quote__follow">Zenkai exists for that exact tension: the part of you that still wants the reference, just in a cleaner, sharper form.</p>
              </aside>

              <div class="zenkai-additional-content">
                {% if settings.additional_content_style == 'expandable' %}
                  {% include 'product-additional-content', section_id: section_id %}
                {% else %}
                  {% include 'product-additional-tabs', section_id: section_id %}
                {% endif %}
              </div>

              {% if social_enable %}
                {% include 'social-sharing',
                  share_title: product.title,
                  share_permalink: product.url,
                  share_image: product
                %}
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if zenkai_mobile_sticky_atc %}
    {% unless isModal %}
      <div class="zenkai-sticky-atc" data-sticky-atc hidden>
        <div class="zenkai-sticky-atc__meta">
          <span class="zenkai-sticky-atc__price" data-sticky-atc-price>{{ current_variant.price | money }}</span>
          <span class="zenkai-sticky-atc__variant" data-sticky-atc-variant>{{ zenkai_current_variant_label }}</span>
        </div>
        <button type="button" class="btn zenkai-sticky-atc__button" data-sticky-atc-button{% unless current_variant.available %} disabled="disabled"{% endunless %}>
          {% if current_variant.available %}
            {{ zenkai_cta_text }}
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>
      </div>
    {% endunless %}
  {% endif %}
</div>

<script>
  (function() {
    function initProductSection{{ section_id }}() {
      var section = document.getElementById('ProductSection-{{ section_id }}');

      if (!section) {
        return;
      }

      var ctaLabel = section.getAttribute('data-product-cta-default') || {{ zenkai_cta_text | json }};
      var mainButton = section.querySelector('[data-add-to-cart]');
      var mainButtonText = section.querySelector('[data-add-to-cart-text]');
      var stickySentinel = section.querySelector('[data-sticky-sentinel]');
      var priceSource = section.querySelector('[data-product-price]');
      var selectSource = section.querySelector('[data-product-select]');
      var variantInputs = section.querySelectorAll('[data-variant-input]');
      var sticky = section.querySelector('[data-sticky-atc]');
      var stickyButton = section.querySelector('[data-sticky-atc-button]');
      var stickyPrice = section.querySelector('[data-sticky-atc-price]');
      var stickyVariant = section.querySelector('[data-sticky-atc-variant]');

      function getVariantLabel() {
        if (!selectSource || !selectSource.options.length) {
          return 'Ready to order';
        }

        var option = selectSource.options[selectSource.selectedIndex];
        var label = option ? option.text : '';

        if (label.indexOf(' - ') !== -1) {
          label = label.split(' - ')[0];
        }

        if (!label || label === 'Default Title') {
          return 'Ready to order';
        }

        return label;
      }

      function syncCta() {
        if (!mainButton) {
          return;
        }

        if (mainButtonText && !mainButton.disabled && mainButtonText.textContent.trim() !== ctaLabel) {
          mainButtonText.textContent = ctaLabel;
        }

        if (stickyButton) {
          stickyButton.disabled = mainButton.disabled;
          stickyButton.textContent = mainButton.disabled ? mainButton.textContent.replace(/\s+/g, ' ').trim() : ctaLabel;
        }
      }

      function syncMeta() {
        if (stickyPrice && priceSource) {
          stickyPrice.textContent = priceSource.textContent.replace(/\s+/g, ' ').trim();
        }

        if (stickyVariant) {
          stickyVariant.textContent = getVariantLabel();
        }
      }

      function syncAll() {
        syncCta();
        syncMeta();
      }

      function syncStickyVisibility(entry) {
        if (!sticky || !stickySentinel) {
          return;
        }

        var sentinelTop = stickySentinel.getBoundingClientRect().top;
        var isIntersecting = entry ? entry.isIntersecting : false;
        var showSticky = sentinelTop < 0 && !isIntersecting;

        sticky.hidden = !showSticky;
        sticky.classList.toggle('is-visible', showSticky);
      }

      syncAll();

      if (selectSource) {
        selectSource.addEventListener('change', function() {
          window.setTimeout(syncAll, 0);
        });
      }

      if (variantInputs.length) {
        Array.prototype.forEach.call(variantInputs, function(input) {
          input.addEventListener('change', function() {
            window.setTimeout(syncAll, 0);
          });
        });
      }

      if (mainButton && window.MutationObserver) {
        new MutationObserver(syncAll).observe(mainButton, {
          attributes: true,
          attributeFilter: ['disabled'],
          childList: true,
          characterData: true
        });
      }

      if (priceSource && window.MutationObserver) {
        new MutationObserver(syncMeta).observe(priceSource, {
          childList: true,
          subtree: true,
          characterData: true
        });
      }

      if (sticky && stickySentinel) {
        if ('IntersectionObserver' in window) {
          var observer = new IntersectionObserver(function(entries) {
            syncStickyVisibility(entries[0]);
          }, {
            threshold: [0, 1]
          });

          observer.observe(stickySentinel);
          syncStickyVisibility();
          window.addEventListener('resize', function() {
            syncStickyVisibility();
          });
        } else {
          var onScroll = function() {
            syncStickyVisibility();
          };

          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll);
          syncStickyVisibility();
        }
      }

      if (stickyButton && mainButton) {
        stickyButton.addEventListener('click', function() {
          if (mainButton.disabled) {
            return;
          }

          mainButton.click();
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProductSection{{ section_id }});
    } else {
      initProductSection{{ section_id }}();
    }
  })();
</script>
