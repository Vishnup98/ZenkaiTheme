{% include 'product-template-variables' %}

{%- assign zenkai_identity_eyebrow = product_identity_eyebrow | default: 'For the ones who never really moved on.' -%}
{%- assign zenkai_subheadline = product_subheadline | default: 'A clean everyday piece for people who still remember exactly how that era felt.' -%}
{%- assign zenkai_cta_text = product_cta_text | default: 'Claim Yours' -%}
{%- assign zenkai_cta_note = product_cta_note | default: 'Made to order. Production starts as soon as you reserve your size.' -%}
{%- assign zenkai_benefit_1 = product_benefit_1 | default: 'Subtle reference that the right people catch' -%}
{%- assign zenkai_benefit_2 = product_benefit_2 | default: 'Clean, premium feel instead of loud novelty merch' -%}
{%- assign zenkai_benefit_3 = product_benefit_3 | default: 'Easy to wear daily, but loaded with meaning' -%}
{%- assign zenkai_urgency_chip = product_urgency_chip | default: 'Printed to order in the USA' -%}
{%- assign zenkai_guarantee_note = product_guarantee_note | default: 'Secure checkout' -%}
{%- assign zenkai_proof_style = product_proof_style | default: 'customer_messages' -%}
{%- assign zenkai_proof_heading = product_proof_heading | default: 'Actual customer message' -%}
{%- assign zenkai_proof_message = product_proof_message | default: '' -%}
{%- assign zenkai_proof_author = product_proof_author | default: '' -%}
{%- assign zenkai_current_variant_label = current_variant.title -%}
{%- assign zenkai_mobile_sticky_atc = true -%}
{%- assign zenkai_secondary_checkout = false -%}
{%- assign zenkai_hide_mobile_breadcrumbs = true -%}
{%- assign zenkai_show_inline_message = false -%}
{%- assign zenkai_rating_count = product.metafields.junip.rating_count | default: 0 | plus: 0 -%}
{%- assign zenkai_show_review_summary = false -%}

{% if product.has_only_default_variant or zenkai_current_variant_label == 'Default Title' %}
  {%- assign zenkai_current_variant_label = 'Ready to order' -%}
{% endif %}

{% if mobile_sticky_atc_enable == false %}
  {%- assign zenkai_mobile_sticky_atc = false -%}
{% endif %}

{% if hide_mobile_breadcrumbs == false %}
  {%- assign zenkai_hide_mobile_breadcrumbs = false -%}
{% endif %}

{% if show_dynamic_checkout_secondary %}
  {%- assign zenkai_secondary_checkout = true -%}
{% endif %}

{% if shop.metafields.junip.onsite_enabled and zenkai_rating_count > 0 %}
  {%- assign zenkai_show_review_summary = true -%}
{% endif %}

{% if zenkai_proof_style == 'customer_messages' and zenkai_proof_message != blank %}
  {%- assign zenkai_show_inline_message = true -%}
{% endif %}

<style>
  #ProductSection-{{ section_id }} .page-content {
    padding-top: 4px;
  }

  #ProductSection-{{ section_id }} .product-single__meta {
    padding-left: 36px;
  }

  .zenkai-breadcrumb {
    margin-bottom: 1rem;
  }

  .zenkai-breadcrumb__list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.8125rem;
    color: #6f7785;
  }

  .zenkai-breadcrumb__link {
    color: #6f7785;
    text-decoration: none;
  }

  .zenkai-breadcrumb__link:hover,
  .zenkai-breadcrumb__link:focus {
    color: #151823;
  }

  .zenkai-breadcrumb--mobile-hidden {
    display: block;
  }

  .zenkai-zoom-hint {
    position: absolute;
    right: 1rem;
    bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 999px;
    background: rgba(21, 24, 35, 0.8);
    color: #fff;
    font-size: 0.75rem;
    line-height: 1;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  #ProductSection-{{ section_id }} .product__main-photos:hover .zenkai-zoom-hint {
    opacity: 1;
  }

  #ProductSection-{{ section_id }} .product-single__header {
    margin-bottom: 1rem;
  }

  .zenkai-identity-eyebrow {
    margin: 0 0 0.5rem;
    color: #8c7451;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  #ProductSection-{{ section_id }} .product-single__title {
    margin-bottom: 0.5rem !important;
    color: #151823;
    font-size: 2rem !important;
    font-weight: 800;
    line-height: 1.05 !important;
    letter-spacing: -0.02em;
  }

  .zenkai-subheadline {
    margin: 0 0 0.875rem;
    color: #2b3345;
    font-size: 1rem;
    font-weight: 500;
    line-height: 1.45;
  }

  .zenkai-proof-strip {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.9rem;
  }

  .zenkai-proof-strip .junip-product-summary {
    display: inline-flex;
    align-items: center;
  }

  .zenkai-inline-proof {
    width: 100%;
    padding: 0.8rem 0.9rem;
    border: 1px solid rgba(21, 24, 35, 0.08);
    border-radius: 14px;
    background: #f7f8fa;
    text-align: left;
  }

  .zenkai-inline-proof__label {
    display: inline-flex;
    margin-bottom: 0.4rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    background: rgba(232, 155, 62, 0.14);
    color: #916322;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .zenkai-inline-proof__message {
    margin: 0;
    color: #151823;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .zenkai-inline-proof__author {
    display: block;
    margin-top: 0.45rem;
    color: #5e6778;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .zenkai-proof-strip__copy,
  .zenkai-proof-pill {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: #f5f6f8;
    color: #151823;
    font-size: 0.8125rem;
    font-weight: 600;
    line-height: 1.2;
  }

  .zenkai-price-card {
    padding: 0.875rem 1rem;
    border: 1px solid rgba(21, 24, 35, 0.08);
    border-radius: 14px;
    background: linear-gradient(180deg, #fff 0%, #faf8f3 100%);
    box-shadow: 0 10px 24px rgba(21, 24, 35, 0.06);
  }

  #ProductSection-{{ section_id }} .product-single__prices {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.65rem;
    margin: 0;
  }

  #ProductSection-{{ section_id }} .product-single__prices .product__price--compare {
    position: relative;
    padding-right: 0;
    color: #7b7e87;
    font-size: 1rem;
    font-weight: 500;
    text-decoration: none;
  }

  #ProductSection-{{ section_id }} .product-single__prices .product__price--compare::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 2px;
    background: rgba(21, 24, 35, 0.45);
    transform: translateY(-50%);
  }

  #ProductSection-{{ section_id }} .product-single__prices .product__price {
    padding-right: 0;
    color: #151823;
    font-size: 1.75rem;
    font-weight: 800;
    line-height: 1;
  }

  #ProductSection-{{ section_id }} .product-single__prices .product__price.sale-price {
    color: #e89b3e;
  }

  #ProductSection-{{ section_id }} .product-single__prices .you-save {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    background: #fff0dc;
    color: #a96414;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .zenkai-benefit-list {
    list-style: none;
    margin: 0.95rem 0 0;
    padding: 0;
  }

  .zenkai-benefit-list li {
    position: relative;
    padding-left: 1.35rem;
    margin-bottom: 0.55rem;
    color: #2b3345;
    font-size: 0.9375rem;
    line-height: 1.45;
  }

  .zenkai-benefit-list li:last-child {
    margin-bottom: 0;
  }

  .zenkai-benefit-list li::before {
    content: "";
    position: absolute;
    top: 0.48rem;
    left: 0;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #e89b3e;
    box-shadow: 0 0 0 4px rgba(232, 155, 62, 0.12);
  }

  .zenkai-product-actions {
    margin-top: 0.85rem;
  }

  .zenkai-form-chip {
    margin: 0 0 0.65rem;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: #151823;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .zenkai-primary-cta {
    min-height: 58px;
    border: 0;
    border-radius: 14px;
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    box-shadow: 0 12px 28px rgba(94, 155, 74, 0.22);
  }

  .zenkai-primary-cta:hover,
  .zenkai-primary-cta:focus {
    transform: translateY(-1px);
  }

  .zenkai-cta-note {
    margin: 0.65rem 0 0;
    color: #556074;
    font-size: 0.875rem;
    line-height: 1.45;
  }

  .zenkai-secondary-checkout {
    margin-top: 0.75rem;
    opacity: 0.9;
  }

  .zenkai-secondary-checkout .shopify-payment-button__button {
    border-radius: 12px !important;
    min-height: 48px !important;
  }

  #ProductSection-{{ section_id }} .variant__label-note {
    display: block;
    margin-top: 0.2rem;
    color: #6d7585;
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.35;
  }

  #ProductSection-{{ section_id }} .variant__label-note--trigger {
    padding: 0;
    border: 0;
    background: none;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.14em;
    cursor: pointer;
  }

  #ProductSection-{{ section_id }} .variant__label-note--trigger:hover,
  #ProductSection-{{ section_id }} .variant__label-note--trigger:focus {
    color: #151823;
  }

  .zenkai-reassurance-row {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.5rem;
    margin: 1rem 0 1.25rem;
  }

  .zenkai-reassurance-item {
    padding: 0.7rem 0.8rem;
    border-radius: 12px;
    background: #f5f6f8;
    color: #151823;
    font-size: 0.8125rem;
    font-weight: 700;
    line-height: 1.3;
    text-align: center;
  }

  #ProductSection-{{ section_id }} .product__policies small {
    display: none !important;
  }

  .zenkai-sticky-atc[hidden] {
    display: none !important;
  }

  .zenkai-sticky-atc {
    position: fixed;
    right: 10px;
    left: 10px;
    bottom: calc(env(safe-area-inset-bottom, 0px) + 10px);
    z-index: 40;
    display: none;
    align-items: center;
    gap: 0.65rem;
    padding: 0.6rem 0.65rem;
    border-radius: 14px;
    background: rgba(21, 24, 35, 0.92);
    box-shadow: 0 14px 28px rgba(0, 0, 0, 0.22);
  }

  .zenkai-sticky-atc.is-visible {
    display: flex;
  }

  .zenkai-sticky-atc__meta {
    flex: 1 1 auto;
    min-width: 0;
  }

  .zenkai-sticky-atc__price {
    display: block;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 800;
    line-height: 1.1;
  }

  .zenkai-sticky-atc__variant {
    display: block;
    margin-top: 0.1rem;
    color: rgba(255, 255, 255, 0.76);
    font-size: 0.7rem;
    font-weight: 600;
    line-height: 1.2;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .zenkai-sticky-atc__button {
    flex: 0 0 auto;
    min-width: 138px;
    min-height: 44px;
    border-radius: 12px;
    border: 0;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .above-fold-indicator {
    position: fixed;
    top: 100vh;
    left: 0;
    right: 0;
    height: 2px;
    background: red;
    z-index: 9999;
    pointer-events: none;
    display: none;
  }

  @media (max-width: 767px) {
    #ProductSection-{{ section_id }} .product-single__meta {
      padding-left: 0;
      margin-top: 0.65rem;
    }

    .zenkai-breadcrumb {
      margin-bottom: 0.35rem;
    }

    {% if zenkai_hide_mobile_breadcrumbs %}
      .zenkai-breadcrumb--mobile-hidden {
        display: none;
      }
    {% endif %}

    #ProductSection-{{ section_id }} .page-content {
      padding-top: 0;
    }

    #ProductSection-{{ section_id }} .product__main-photos-wrapper {
      margin-bottom: 0.1rem;
    }

    #ProductSection-{{ section_id }} .product__photo-dots {
      margin-top: 0.15rem;
    }

    #ProductSection-{{ section_id }} .product-single__title {
      font-size: 1.45rem !important;
    }

    .zenkai-subheadline {
      margin-bottom: 0.7rem;
      font-size: 0.95rem;
    }

    #ProductSection-{{ section_id }} .product-single__prices .product__price {
      font-size: 1.45rem;
    }

    #ProductSection-{{ section_id }} .product-single__prices .product__price--compare {
      font-size: 0.9rem;
    }

    #ProductSection-{{ section_id }} .product-single__prices .you-save {
      font-size: 0.75rem;
    }

    .zenkai-price-card {
      padding: 0.7rem 0.8rem;
    }

    .zenkai-proof-strip__copy,
    .zenkai-proof-pill {
      font-size: 0.75rem;
    }

    .zenkai-inline-proof {
      padding: 0.7rem 0.75rem;
    }

    .zenkai-inline-proof__message {
      font-size: 0.85rem;
    }

    .zenkai-benefit-list li {
      font-size: 0.875rem;
    }

    .zenkai-form-chip {
      font-size: 0.6875rem;
    }

    .zenkai-primary-cta {
      min-height: 52px;
      font-size: 0.95rem;
    }

    .zenkai-cta-note {
      font-size: 0.8125rem;
    }

    .zenkai-reassurance-row {
      grid-template-columns: 1fr;
      margin-bottom: 1rem;
    }

    .zenkai-reassurance-item {
      text-align: left;
    }
  }

  @media (min-width: 768px) {
    .zenkai-sticky-atc {
      display: none !important;
    }
  }
</style>

<div
  id="ProductSection-{{ section_id }}"
  class="product-section"
  data-section-id="{{ section_id }}"
  data-section-type="product-template"
  data-product-cta-default="{{ zenkai_cta_text | escape }}"
  {% if isModal %}data-subsection{% endif %}
  data-variant-type="{{ variant_type }}"
  {% if inventory_enable %}data-inventory="true" data-inventory-threshold="{{ inventory_threshold }}"{% endif %}
  {% if inventory_transfers_enable %}data-incoming-inventory="true"{% endif %}
  {% if product_image_type == 'stacked' %}data-images-stacked="true"{% endif %}
  data-video-style="{{ video_style }}"
  {% unless isModal %}data-enable-history-state="true"{% endunless %}
>
  <div class="page-content">
    <div class="page-width">
      <nav aria-label="breadcrumb" class="zenkai-breadcrumb{% if zenkai_hide_mobile_breadcrumbs %} zenkai-breadcrumb--mobile-hidden{% endif %}">
        <ol class="zenkai-breadcrumb__list">
          <li>
            <a href="/" class="zenkai-breadcrumb__link">Home</a>
          </li>
          <li aria-hidden="true">/</li>
          <li>
            <a href="/collections/all" class="zenkai-breadcrumb__link">All Products</a>
          </li>
          <li aria-hidden="true">/</li>
          <li>{{ product.title | truncate: 30 }}</li>
        </ol>
      </nav>

      <div class="grid">
        <div class="grid__item {{ product_image_width }}">
          {% include 'product-images',
            section_id: section_id,
            isModal: isModal,
            video_looping: video_looping,
            video_style: video_style
          %}

          <div class="zenkai-zoom-hint">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
              <line x1="11" y1="8" x2="11" y2="14"></line>
              <line x1="8" y1="11" x2="14" y2="11"></line>
            </svg>
            Click to zoom
          </div>
        </div>

        <div class="grid__item {{ product_description_width }}{% if product_image_type == 'stacked' %} product-single__sticky{% endif %}">
          <div class="product-single__meta">
            <div class="product-single__header small--text-center">
              {% if settings.vendor_enable %}
                <div class="product-single__vendor">{{ product.vendor }}</div>
              {% endif %}

              <p class="zenkai-identity-eyebrow">{{ zenkai_identity_eyebrow }}</p>

              {% if isModal %}
                <p class="h2 product-single__title">{{ product.title }}</p>
              {% else %}
                <h1 class="h2 product-single__title">{{ product.title }}</h1>
              {% endif %}

              <p class="zenkai-subheadline">{{ zenkai_subheadline }}</p>

              {% if zenkai_show_review_summary or zenkai_proof_style != 'none' %}
                <div class="zenkai-proof-strip">
                  {% if zenkai_show_review_summary %}
                    {% render 'junip-product-summary', product: product %}
                    <span class="zenkai-proof-strip__copy">Trusted by fans who already grabbed theirs</span>
                  {% elsif zenkai_show_inline_message %}
                    <div class="zenkai-inline-proof">
                      <span class="zenkai-inline-proof__label">{{ zenkai_proof_heading }}</span>
                      <p class="zenkai-inline-proof__message">{{ zenkai_proof_message | strip_html | truncate: 110 }}</p>
                      {% if zenkai_proof_author != blank %}
                        <span class="zenkai-inline-proof__author">- {{ zenkai_proof_author }}</span>
                      {% endif %}
                    </div>
                  {% elsif zenkai_proof_style == 'ugc_gallery' %}
                    <span class="zenkai-proof-pill">Real customer photos below</span>
                    <span class="zenkai-proof-pill">Made to be worn in the wild</span>
                  {% else %}
                    <span class="zenkai-proof-pill">Not loud merch. Just the reference.</span>
                    <span class="zenkai-proof-pill">Easy to wear daily.</span>
                  {% endif %}
                </div>
              {% endif %}

              <div class="zenkai-price-card">
                <div class="product-single__prices" data-price-wrapper>
                  {% if current_variant.compare_at_price > current_variant.price %}
                    <span class="product__price product__price--compare" data-product-price-compare>
                      {{ current_variant.compare_at_price | money }}
                    </span>
                  {% endif %}

                  <span class="product__price{% if current_variant.compare_at_price > current_variant.price %} sale-price{% endif %}" data-product-price>
                    {{ current_variant.price | money }}
                  </span>

                  {% if current_variant.compare_at_price > current_variant.price %}
                    <span class="you-save">
                      Save {{ current_variant.compare_at_price | minus: current_variant.price | money }}
                    </span>
                  {% endif %}
                </div>
              </div>

              <ul class="zenkai-benefit-list" role="list">
                <li>{{ zenkai_benefit_1 }}</li>
                <li>{{ zenkai_benefit_2 }}</li>
                <li>{{ zenkai_benefit_3 }}</li>
              </ul>
            </div>

            {% unless isModal %}
              {% include 'product-form',
                section_id: section_id,
                variant_type: variant_type,
                variant_labels_enable: variant_labels_enable,
                quantity_enable: quantity_enable,
                enable_payment_button: enable_payment_button,
                product_cta_text: zenkai_cta_text,
                product_cta_note: zenkai_cta_note,
                product_urgency_chip: zenkai_urgency_chip,
                show_dynamic_checkout_secondary: zenkai_secondary_checkout
              %}
            {% else %}
              <div id="ProductFormPlaceholder-{{ section_id }}" data-url="{{ product.url | within: collection }}" data-template="{{ product.template_suffix }}" class="product-form-holder">
                {% if product.options.size > 0 %}
                  {% for i in (1..product.options.size) %}
                    <div class="placeholder-content" style="min-height: 86px; max-width: 66%;"></div>
                  {% endfor %}
                {% endif %}
                <div class="placeholder-content" style="min-height: 86px;"></div>
              </div>
            {% endunless %}

            <div class="zenkai-reassurance-row" role="list">
              <div class="zenkai-reassurance-item" role="listitem">Printed to order</div>
              <div class="zenkai-reassurance-item" role="listitem">Free U.S. shipping</div>
              <div class="zenkai-reassurance-item" role="listitem">{{ zenkai_guarantee_note }}</div>
            </div>

            {% if settings.additional_content_style == 'expandable' %}
              {% include 'product-additional-content', section_id: section_id %}
            {% else %}
              {% include 'product-additional-tabs', section_id: section_id %}
            {% endif %}

            {% if social_enable %}
              {% include 'social-sharing',
                share_title: product.title,
                share_permalink: product.url,
                share_image: product
              %}
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>

  {% if zenkai_mobile_sticky_atc %}
    {% unless isModal %}
      <div class="zenkai-sticky-atc" data-sticky-atc hidden>
        <div class="zenkai-sticky-atc__meta">
          <span class="zenkai-sticky-atc__price" data-sticky-atc-price>{{ current_variant.price | money }}</span>
          <span class="zenkai-sticky-atc__variant" data-sticky-atc-variant>{{ zenkai_current_variant_label }}</span>
        </div>
        <button type="button" class="btn zenkai-sticky-atc__button" data-sticky-atc-button{% unless current_variant.available %} disabled="disabled"{% endunless %}>
          {% if current_variant.available %}
            {{ zenkai_cta_text }}
          {% else %}
            {{ 'products.product.sold_out' | t }}
          {% endif %}
        </button>
      </div>
    {% endunless %}
  {% endif %}
</div>

<script>
  (function() {
    function initProductSection{{ section_id }}() {
      var section = document.getElementById('ProductSection-{{ section_id }}');

      if (!section) {
        return;
      }

      var ctaLabel = section.getAttribute('data-product-cta-default') || {{ zenkai_cta_text | json }};
      var mainButton = section.querySelector('[data-add-to-cart]');
      var mainButtonText = section.querySelector('[data-add-to-cart-text]');
      var anchor = section.querySelector('[data-product-form-anchor]');
      var priceSource = section.querySelector('[data-product-price]');
      var selectSource = section.querySelector('[data-product-select]');
      var variantInputs = section.querySelectorAll('[data-variant-input]');
      var sticky = section.querySelector('[data-sticky-atc]');
      var stickyButton = section.querySelector('[data-sticky-atc-button]');
      var stickyPrice = section.querySelector('[data-sticky-atc-price]');
      var stickyVariant = section.querySelector('[data-sticky-atc-variant]');

      function getVariantLabel() {
        if (!selectSource || !selectSource.options.length) {
          return 'Ready to order';
        }

        var option = selectSource.options[selectSource.selectedIndex];
        var label = option ? option.text : '';

        if (label.indexOf(' - ') !== -1) {
          label = label.split(' - ')[0];
        }

        if (!label || label === 'Default Title') {
          return 'Ready to order';
        }

        return label;
      }

      function syncCta() {
        if (!mainButton) {
          return;
        }

        if (mainButtonText && !mainButton.disabled && mainButtonText.textContent.trim() !== ctaLabel) {
          mainButtonText.textContent = ctaLabel;
        }

        if (stickyButton) {
          stickyButton.disabled = mainButton.disabled;
          stickyButton.textContent = mainButton.disabled ? mainButton.textContent.replace(/\s+/g, ' ').trim() : ctaLabel;
        }
      }

      function syncMeta() {
        if (stickyPrice && priceSource) {
          stickyPrice.textContent = priceSource.textContent.replace(/\s+/g, ' ').trim();
        }

        if (stickyVariant) {
          stickyVariant.textContent = getVariantLabel();
        }
      }

      function syncAll() {
        syncCta();
        syncMeta();
      }

      syncAll();

      if (selectSource) {
        selectSource.addEventListener('change', function() {
          window.setTimeout(syncAll, 0);
        });
      }

      if (variantInputs.length) {
        Array.prototype.forEach.call(variantInputs, function(input) {
          input.addEventListener('change', function() {
            window.setTimeout(syncAll, 0);
          });
        });
      }

      if (mainButton && window.MutationObserver) {
        new MutationObserver(syncAll).observe(mainButton, {
          attributes: true,
          attributeFilter: ['disabled'],
          childList: true,
          subtree: true,
          characterData: true
        });
      }

      if (priceSource && window.MutationObserver) {
        new MutationObserver(syncMeta).observe(priceSource, {
          childList: true,
          subtree: true,
          characterData: true
        });
      }

      if (sticky && anchor) {
        if ('IntersectionObserver' in window) {
          var observer = new IntersectionObserver(function(entries) {
            var entry = entries[0];
            var isVisible = entry && entry.isIntersecting;
            var showSticky = !isVisible || (entry && entry.intersectionRatio < 0.35);

            sticky.hidden = !showSticky;
            sticky.classList.toggle('is-visible', showSticky);
          }, {
            threshold: [0, 0.35]
          });

          observer.observe(anchor);
        } else {
          sticky.hidden = false;
          sticky.classList.add('is-visible');
        }
      }

      if (stickyButton && mainButton) {
        stickyButton.addEventListener('click', function() {
          if (mainButton.disabled) {
            return;
          }

          mainButton.click();
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initProductSection{{ section_id }});
    } else {
      initProductSection{{ section_id }}();
    }
  })();
</script>

