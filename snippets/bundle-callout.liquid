        });
      }
      function setLabel(text) {
        var labelEl = addBtn.querySelector('[data-zk-add-label]');
        if (labelEl) labelEl.textContent = text;
      }
      function updateAddState() {
        if (!allSelected()) {
          addBtn.disabled = true; addBtn.setAttribute('aria-disabled', 'true');
          setLabel('Select options'); return;
        }
        var v = findVariant();
        if (!v) { addBtn.disabled = true; setLabel('Unavailable'); return; }
        if (!v.available) { addBtn.disabled = true; setLabel('Sold out'); return; }
        addBtn.disabled = false;
        addBtn.setAttribute('aria-disabled', 'false');
        addBtn.dataset.variantId = v.id;
        setLabel('Add to bundle');
      }

      var cardImg = item.querySelector('.zk-bundle__media img');

      function findBestVariantByPartialSelection() {
        // Return the first variant matching all currently-selected options,
        // ignoring unselected ones. Used to pick an image when color is set
        // but size isn't yet.
        return variants.find(function(v) {
          return v.options.every(function(val, i) {
            return selection[i] === undefined || val === selection[i];
          });
        });
      }

      function swapCardImage(src) {
        if (!cardImg || !src) return;
        if (!cardImg.dataset.zkOriginalSrc) cardImg.dataset.zkOriginalSrc = cardImg.src;
        if (cardImg.src === src) return;
        cardImg.src = src;
        cardImg.removeAttribute('srcset');
      }

      optionEls.forEach(function(optEl) {
        var idx = parseInt(optEl.dataset.optionIndex, 10);
        var isColor = optEl.classList.contains('zk-bundle__option--color');
        var selectEl = optEl.querySelector('[data-zk-select]');

        // Size dropdown
        if (selectEl) {
          selectEl.addEventListener('change', function() {
            selection[idx] = selectEl.value;
            updateAddState();
          });
          return;
        }

        // Pill buttons / color swatches
        var btns = optEl.querySelectorAll('.zk-bundle__option-btn, .zk-bundle__swatch');
        btns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            btns.forEach(function(b) { b.setAttribute('aria-checked', 'false'); });
            btn.setAttribute('aria-checked', 'true');
            selection[idx] = btn.dataset.optionValue;
            if (isColor) {
              var match = findBestVariantByPartialSelection();
              if (match && match.image) swapCardImage(match.image);
            }
            updateAddState();
          });
        });
      });

      /* ===== Sensible defaults: first color + preferred size (L > M > XL > S > first) ===== */
      (function selectDefaults() {
        if (!optionEls.length) return;
        var colorIdx = -1, sizeIdx = -1;
        optionEls.forEach(function(el) {
          var i = parseInt(el.dataset.optionIndex, 10);
          if (el.classList.contains('zk-bundle__option--color')) colorIdx = i;
          if (el.classList.contains('zk-bundle__option--size')) sizeIdx = i;
        });

        // Default color: first color with at least one available variant.
        var defaultColor = null;
        if (colorIdx >= 0) {
          var seenColors = {};
          for (var i = 0; i < variants.length; i++) {
            var v = variants[i];
            var c = v.options[colorIdx];
            if (v.available && !seenColors[c]) { defaultColor = c; break; }
            seenColors[c] = true;
          }
          if (!defaultColor && variants.length) defaultColor = variants[0].options[colorIdx];
          if (defaultColor) selection[colorIdx] = defaultColor;
        }

        // Default size: preferred order, filtered to variants matching default color.
        if (sizeIdx >= 0) {
          var preferred = ['L', 'M', 'XL', 'S', 'XS', 'XXL', '2XL', '3XL', '4XL'];
          var candidates = variants.filter(function(v) {
            if (!v.available) return false;
            return colorIdx < 0 || v.options[colorIdx] === defaultColor;
          });
          var availableSizes = {};
          candidates.forEach(function(v) { availableSizes[v.options[sizeIdx]] = true; });
          var defaultSize = null;
          for (var j = 0; j < preferred.length; j++) {
            if (availableSizes[preferred[j]]) { defaultSize = preferred[j]; break; }
          }
          // Fallback: first available size, else first declared.
          if (!defaultSize) {
            var keys = Object.keys(availableSizes);
            if (keys.length) defaultSize = keys[0];
            else if (variants.length) defaultSize = variants[0].options[sizeIdx];
          }
          if (defaultSize) selection[sizeIdx] = defaultSize;
        }

        // Non-color, non-size options: just pick first value.
        optionEls.forEach(function(el) {
          var idx = parseInt(el.dataset.optionIndex, 10);
          if (selection[idx] !== undefined) return;
          var btn = el.querySelector('.zk-bundle__option-btn, .zk-bundle__swatch');
          if (btn) { selection[idx] = btn.dataset.optionValue; return; }
          var sel = el.querySelector('[data-zk-select]');
          if (sel) {
            var opt = Array.prototype.find.call(sel.options, function(o) { return !o.disabled && o.value; });
            if (opt) selection[idx] = opt.value;
          }
        });

        // Reflect defaults in the UI.
        optionEls.forEach(function(optEl) {
          var idx = parseInt(optEl.dataset.optionIndex, 10);
          var chosen = selection[idx];
          if (chosen === undefined) return;
          var sel = optEl.querySelector('[data-zk-select]');
          if (sel) { sel.value = chosen; return; }
          var btns = optEl.querySelectorAll('.zk-bundle__option-btn, .zk-bundle__swatch');
          btns.forEach(function(btn) {
            btn.setAttribute('aria-checked', btn.dataset.optionValue === chosen ? 'true' : 'false');
          });
        });

        // Swap to the default-color variant's image.
        if (colorIdx >= 0) {
          var match = findBestVariantByPartialSelection();
          if (match && match.image) swapCardImage(match.image);
        }

        updateAddState();
      })();

      if (!addBtn) return;

      var handleAddClick = function(e) {
        if (e && e.preventDefault) e.preventDefault();
        if (e && e.stopPropagation) e.stopPropagation();
        if (e && e.stopImmediatePropagation) e.stopImmediatePropagation();
        var variantId = addBtn.dataset.variantId;
        if (!variantId || addBtn.disabled) return;
        addBtn.disabled = true;
        addBtn.dataset.state = 'loading';
        var defaultEl = addBtn.querySelector('.zk-bundle__add-default');
        var loadingEl = addBtn.querySelector('.zk-bundle__add-loading');
        var successEl = addBtn.querySelector('.zk-bundle__add-success');
        defaultEl.hidden = true;
        loadingEl.hidden = false;

        if (window.console && window.console.debug) {
          console.debug('[zk-bundle] add click — variant', variantId);
        }

        // Defer the heavy suppression setup + network dispatch behind a
        // double requestAnimationFrame so the browser PAINTS the loading
        // state before we block the main thread. Without this, the ~50-
        // 150ms of synchronous suppression work delays the first paint
        // and the click feels dead — and the "Adding…" animation barely
        // has time to render before success flips in.
        // 900ms ≈ dot 2.5 of the 1.5s cycle, so users see the full
        // "Adding" → "Adding." → "Adding.." progression.
        var MIN_LOADING_MS = 900;
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            // Arm drawer suppression *before* the add fires — 4.5s window.
            window.__zkBundleSuppressDrawer(4500);

            // Measure loading duration from *here* (post-paint), so
            // MIN_LOADING_MS reflects user-perceived loading time.
            var loadingShownAt = Date.now();

            addToCartXHR(parseInt(variantId, 10))
              .then(function () {
                var elapsed = Date.now() - loadingShownAt;
                var toSuccess = Math.max(0, MIN_LOADING_MS - elapsed);
                setTimeout(function () {
                  addBtn.dataset.state = 'success';
                  loadingEl.hidden = true;
                  successEl.hidden = false;
                  // Keep button disabled — stay on "Added" permanently.
                  // Refresh BOTH desktop + mobile instances, not just the
                  // current one — otherwise the other instance's progress
                  // bar goes stale (user reported desktop showing $20 off
                  // while mobile correctly showed $10 for the same cart).
                  if (typeof window.__zkBundleRefreshAll === 'function') {
                    window.__zkBundleRefreshAll();
                  } else {
                    refreshCartState();
                  }
                }, toSuccess);
              })
              .catch(function (err) {
                console.error('[zk-bundle]', err);
                addBtn.dataset.state = '';
                loadingEl.hidden = true;
                defaultEl.hidden = false;
                setLabel('Try again');
                showToast('Couldn\u2019t add that — please try again.', 'error');
                setTimeout(function () {
                  setLabel('Add to bundle');
                  addBtn.disabled = false;
                }, 2400);
              });
          });
        });
      };

      addBtn.__zkHandleAdd = handleAddClick;
      // Belt-and-suspenders: if the window-level capture shield somehow
      // fails to win the race against a third-party handler, this
      // button-level capture listener still fires the add logic.
      addBtn.addEventListener('click', handleAddClick, { capture: true });
    });
  };

  document.querySelectorAll('.zk-bundle').forEach(window.__zkBundleInitInstance);
})();
</script>

  {%- endif -%}
{%- endif -%}
