{%- comment -%}
  Bundle Callout — PDP bundle upsell with live reward progress.

  Usage: {% include 'bundle-callout', bundle_slot: 'desktop' %}
         {% include 'bundle-callout', bundle_slot: 'mobile' %}

  Color mapping uses the exact Globo palette supplied by the shop admin —
  value name → hex. Falls back to a neutral tan if the value isn't mapped.

  Hides silently if metafield unset, collection < 2 items, or no others available.
{%- endcomment -%}

{%- assign bundle_slot = bundle_slot | default: 'default' -%}

{%- assign bundle_mf = product.metafields.custom.pdp_bundle_upsell_collection -%}
{%- assign bundle_handle = blank -%}
{%- if bundle_mf.first.handle -%}
  {%- assign bundle_handle = bundle_mf.first.handle -%}
{%- elsif bundle_mf.value.handle -%}
  {%- assign bundle_handle = bundle_mf.value.handle -%}
{%- elsif bundle_mf.handle -%}
  {%- assign bundle_handle = bundle_mf.handle -%}
{%- endif -%}

{%- assign bundle_collection = blank -%}
{%- if bundle_handle != blank -%}
  {%- assign bundle_collection = collections[bundle_handle] -%}
{%- endif -%}

{%- if bundle_collection != blank and bundle_collection.products_count > 1 -%}

  {%- assign other_count = 0 -%}
  {%- for p in bundle_collection.products -%}
    {%- if p.id != product.id and p.available -%}
      {%- assign other_count = other_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if other_count >= 1 -%}
    {%- assign total_possible = other_count | plus: 1 -%}
    {%- assign show_tier_4 = false -%}
    {%- if total_possible >= 4 -%}
      {%- assign show_tier_4 = true -%}
    {%- endif -%}
    {%- assign collection_short_title = bundle_collection.title | replace: 'Collection', '' | strip -%}

    {%- capture bundle_product_ids -%}
      {%- for p in bundle_collection.products -%}{{ p.id }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}
    {%- endcapture -%}

<section class="zk-bundle zk-bundle--{{ bundle_slot }}"
  data-zk-tiers="{% if show_tier_4 %}2,3,4{% else %}2,3{% endif %}"
  data-zk-product-ids="{{ bundle_product_ids | strip }}"
  aria-labelledby="zk-bundle-heading-{{ bundle_slot }}-{{ product.id }}">
  <div class="zk-bundle__inner">

    <div class="zk-bundle__head">
      <span class="zk-bundle__eyebrow">More from this world</span>
      <h3 id="zk-bundle-heading-{{ bundle_slot }}-{{ product.id }}" class="zk-bundle__title">
        Complete the {{ collection_short_title }}
      </h3>
      <p class="zk-bundle__message" data-zk-message>
        Pick any 2 for $5 off. Any 3 for $10 off.{% if show_tier_4 %} Any 4+ for $20 off.{% endif %}
      </p>
    </div>

    <div class="zk-bundle__progress" data-zk-progress>
      <div class="zk-bundle__progress-track">
        <div class="zk-bundle__progress-fill" data-zk-progress-fill style="width:0%"></div>
      </div>
      <ul class="zk-bundle__milestones" role="list">
        <li class="zk-bundle__milestone" data-zk-milestone="2" style="left:33%">
          <span class="zk-bundle__milestone-dot" aria-hidden="true">$</span>
          <span class="zk-bundle__milestone-label">Save $5</span>
        </li>
        <li class="zk-bundle__milestone" data-zk-milestone="3" style="left:66%">
          <span class="zk-bundle__milestone-dot" aria-hidden="true">$$</span>
          <span class="zk-bundle__milestone-label">Save $10</span>
        </li>
        {%- if show_tier_4 -%}
        <li class="zk-bundle__milestone" data-zk-milestone="4" style="left:100%">
          <span class="zk-bundle__milestone-dot" aria-hidden="true">$$$</span>
          <span class="zk-bundle__milestone-label">Save $20</span>
        </li>
        {%- endif -%}
      </ul>
    </div>

    <div class="zk-bundle__carousel" role="list" data-zk-carousel>
      {%- for p in bundle_collection.products -%}
        {%- if p.id != product.id and p.available -%}
          {%- assign first_image = p.featured_image | default: p.images.first -%}
          {%- assign is_single_variant = false -%}
          {%- if p.has_only_default_variant -%}
            {%- assign is_single_variant = true -%}
          {%- endif -%}

          <article class="zk-bundle__card" role="listitem" data-zk-item data-product-id="{{ p.id }}">
            <a href="{{ p.url }}" class="zk-bundle__media" tabindex="-1" aria-hidden="true">
              {%- if first_image -%}
                <img
                  src="{{ first_image | img_url: '480x480', crop: 'center' }}"
                  srcset="{{ first_image | img_url: '360x360', crop: 'center' }} 1x, {{ first_image | img_url: '720x720', crop: 'center' }} 2x"
                  alt=""
                  width="200"
                  height="200"
                  loading="lazy">
              {%- endif -%}
            </a>

            <div class="zk-bundle__info">
              <a href="{{ p.url }}" class="zk-bundle__name">{{ p.title }}</a>
              <span class="zk-bundle__price">{{ p.price | money_without_trailing_zeros }}</span>
            </div>

            {%- unless is_single_variant -%}
              <div class="zk-bundle__options">
                {%- for option in p.options_with_values -%}
                  {%- assign option_name_downcase = option.name | downcase -%}
                  {%- assign is_color = false -%}
                  {%- if option_name_downcase contains 'color' or option_name_downcase contains 'colour' -%}
                    {%- assign is_color = true -%}
                  {%- endif -%}
                  <div class="zk-bundle__option{% if is_color %} zk-bundle__option--color{% endif %}" data-option-index="{{ forloop.index0 }}">
                    <span class="zk-bundle__option-label">{{ option.name }}</span>
                    <div class="zk-bundle__option-values" role="radiogroup" aria-label="{{ option.name | escape }}">
                      {%- for value in option.values -%}
                        {%- if is_color -%}
                          {%- assign v_lower = value | downcase -%}
                          {%- assign sw_color = '#c7bda5' -%}
                          {%- case v_lower -%}
                            {%- when 'black', 'solid black', 'jet black' -%}{%- assign sw_color = '#000000' -%}
                            {%- when 'navy' -%}{%- assign sw_color = '#1e334c' -%}
                            {%- when 'navy blue' -%}{%- assign sw_color = '#012b67' -%}
                            {%- when 'navy blazer' -%}{%- assign sw_color = '#242b36' -%}
                            {%- when 'classic navy' -%}{%- assign sw_color = '#292d3e' -%}
                            {%- when 'true navy' -%}{%- assign sw_color = '#2e3550' -%}
                            {%- when 'oxford navy' -%}{%- assign sw_color = '#000080' -%}
                            {%- when 'solid midnight navy' -%}{%- assign sw_color = '#0f1f2c' -%}
                            {%- when 'olive' -%}{%- assign sw_color = '#5c5850' -%}
                            {%- when 'ivory' -%}{%- assign sw_color = '#f4ead2' -%}
                            {%- when 'dark chocolate' -%}{%- assign sw_color = '#3c2d27' -%}
                            {%- when 'solid dark chocolate' -%}{%- assign sw_color = '#3c302f' -%}
                            {%- when 'forest green' -%}{%- assign sw_color = '#263c30' -%}
                            {%- when 'solid forest green' -%}{%- assign sw_color = '#213933' -%}
                            {%- when 'dark green' -%}{%- assign sw_color = '#20331f' -%}
                            {%- when 'light blue' -%}{%- assign sw_color = '#9dbed7' -%}
                            {%- when 'solid light blue' -%}{%- assign sw_color = '#b5ced4' -%}
                            {%- when 'sky blue' -%}{%- assign sw_color = '#87ceeb' -%}
                            {%- when 'blue spruce' -%}{%- assign sw_color = '#596b5e' -%}
                            {%- when 'sage' -%}{%- assign sw_color = '#585743' -%}
                            {%- when 'washed denim' -%}{%- assign sw_color = '#96a6c2' -%}
                            {%- when 'denim' -%}{%- assign sw_color = '#5a5d67' -%}
                            {%- when 'blue aqua' -%}{%- assign sw_color = '#82bcdf' -%}
                            {%- when 'light pink' -%}{%- assign sw_color = '#f3d7dc' -%}
                            {%- when 'white' -%}{%- assign sw_color = '#f3f3f3' -%}
                            {%- when 'solid white', 'arctic white' -%}{%- assign sw_color = '#ffffff' -%}
                            {%- when 'lavender' -%}{%- assign sw_color = '#d1bbe0' -%}
                            {%- when 'bone' -%}{%- assign sw_color = '#fae8d7' -%}
                            {%- when 'grape' -%}{%- assign sw_color = '#705e77' -%}
                            {%- when 'chambray' -%}{%- assign sw_color = '#d6ebf6' -%}
                            {%- when 'berry' -%}{%- assign sw_color = '#8e607d' -%}
                            {%- when 'graphite' -%}{%- assign sw_color = '#4f4848' -%}
                            {%- when 'granite' -%}{%- assign sw_color = '#a0a5a3' -%}
                            {%- when 'flo blue' -%}{%- assign sw_color = '#6c77b3' -%}
                            {%- when 'orchid' -%}{%- assign sw_color = '#ebcbe4' -%}
                            {%- when 'espresso' -%}{%- assign sw_color = '#846753' -%}
                            {%- when 'khaki' -%}{%- assign sw_color = '#b0a98b' -%}
                            {%- when 'mystic blue' -%}{%- assign sw_color = '#5e70a9' -%}
                            {%- when 'seafoam' -%}{%- assign sw_color = '#70a799' -%}
                            {%- when 'brick' -%}{%- assign sw_color = '#90535c' -%}
                            {%- when 'maroon' -%}{%- assign sw_color = '#803246' -%}
                            {%- when 'solid maroon' -%}{%- assign sw_color = '#4c272a' -%}
                            {%- when 'cardinal' -%}{%- assign sw_color = '#672438' -%}
                            {%- when 'solid cardinal red' -%}{%- assign sw_color = '#ff0000' -%}
                            {%- when 'purple' -%}{%- assign sw_color = '#4d3e7a' -%}
                            {%- when 'solid purple rush' -%}{%- assign sw_color = '#422568' -%}
                            {%- when 'pepper' -%}{%- assign sw_color = '#595753' -%}
                            {%- when 'grey', 'gray' -%}{%- assign sw_color = '#9b9b9b' -%}
                            {%- when 'solid light grey' -%}{%- assign sw_color = '#999798' -%}
                            {%- when 'charcoal heather' -%}{%- assign sw_color = '#41424a' -%}
                            {%- when 'solid heavy metal' -%}{%- assign sw_color = '#525a5b' -%}
                            {%- when 'solid natural' -%}{%- assign sw_color = '#eee5d3' -%}
                            {%- when 'solid royal' -%}{%- assign sw_color = '#1b5091' -%}
                            {%- when 'solid desert pink' -%}{%- assign sw_color = '#ffc0cb' -%}
                            {%- when 'solid cream' -%}{%- assign sw_color = '#fffdd0' -%}
                          {%- endcase -%}
                          <button type="button" class="zk-bundle__swatch" role="radio" aria-checked="false" data-option-value="{{ value | escape }}" title="{{ value | escape }}" style="background-color: {{ sw_color }}">
                            <span class="zk-bundle__swatch-label">{{ value }}</span>
                          </button>
                        {%- else -%}
                          <button type="button" class="zk-bundle__option-btn" role="radio" aria-checked="false" data-option-value="{{ value | escape }}">{{ value }}</button>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- endunless -%}

            <script type="application/json" data-zk-variants>[{%- for v in p.variants -%}{"id":{{ v.id }},"available":{{ v.available }},"options":{{ v.options | json }}}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}]</script>

            <button type="button" class="zk-bundle__add" data-zk-add {% if is_single_variant %}data-variant-id="{{ p.selected_or_first_available_variant.id }}"{% else %}disabled aria-disabled="true"{% endif %}>
              <span class="zk-bundle__add-default">{% if is_single_variant %}Add{% else %}Select options{% endif %}</span>
              <span class="zk-bundle__add-loading" hidden aria-hidden="true"><span class="zk-bundle__spinner"></span></span>
              <span class="zk-bundle__add-success" hidden aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><path d="M2 7l3 3 7-7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Added
              </span>
            </button>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <p class="zk-bundle__foot">
      <svg class="zk-bundle__foot-icon" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true"><path d="M2 6l2.5 2.5L10 3" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Discount applies automatically at checkout.
    </p>

  </div>
</section>

<style>
  .zk-bundle {
    margin: 24px 0;
    --zk-ink: #1a1b2e;
    --zk-ink-soft: #5a5f75;
    --zk-ink-faded: #8a8fa5;
    --zk-bg: #ffffff;
    --zk-bg-deep: #faf9f6;
    --zk-border: rgba(26, 27, 46, 0.12);
    --zk-border-strong: rgba(26, 27, 46, 0.2);
    --zk-surface: #ffffff;
    --zk-cta: #e85d3a;
    --zk-cta-hover: #d14e2d;
    --zk-success: #4a7d3d;
    --zk-muted: #cfc9bc;
    --zk-accent-soft: #e8eaf8;
  }
  .zk-bundle__inner {
    background: var(--zk-bg);
    border: 1px solid var(--zk-border);
    border-radius: 18px;
    padding: 20px 18px 16px;
    box-shadow: 0 14px 30px rgba(26, 27, 46, 0.05);
  }

  /* Responsive slot visibility */
  .zk-bundle--desktop { display: none; }
  .zk-bundle--mobile { display: block; }
  @media (min-width: 769px) {
    .zk-bundle--desktop { display: block; }
    .zk-bundle--mobile { display: none; }
  }

  /* Ensure [hidden] on inner spans is respected inside flex button */
  .zk-bundle__add [hidden] { display: none !important; }

  .zk-bundle__head { text-align: center; margin-bottom: 14px; }
  .zk-bundle__eyebrow {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
    color: var(--zk-cta);
    margin-bottom: 4px;
  }
  .zk-bundle__title {
    font-size: 20px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 6px;
    color: var(--zk-ink);
    letter-spacing: -0.01em;
  }
  .zk-bundle__message {
    font-size: 14px;
    line-height: 1.4;
    margin: 0;
    color: var(--zk-ink-soft);
  }
  .zk-bundle__message strong { color: var(--zk-ink); font-weight: 700; }

  /* Progress bar with milestones */
  .zk-bundle__progress {
    position: relative;
    margin: 22px 4px 34px;
  }
  .zk-bundle__progress-track {
    position: relative;
    height: 4px;
    background: var(--zk-accent-soft);
    border-radius: 999px;
    overflow: hidden;
  }
  .zk-bundle__progress-fill {
    position: absolute;
    inset: 0 auto 0 0;
    background: linear-gradient(90deg, var(--zk-cta) 0%, #f5845a 100%);
    border-radius: 999px;
    transition: width 350ms cubic-bezier(.2,.8,.2,1);
  }
  .zk-bundle__milestones {
    position: absolute; inset: 0; margin: 0; padding: 0; list-style: none; pointer-events: none;
  }
  .zk-bundle__milestone {
    position: absolute; top: 50%; transform: translate(-50%, -50%);
    display: flex; flex-direction: column; align-items: center; gap: 4px;
  }
  .zk-bundle__milestone-dot {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: var(--zk-surface);
    border: 2px solid var(--zk-border-strong);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800; color: var(--zk-ink-faded);
    transition: all 200ms ease; letter-spacing: -0.5px;
  }
  .zk-bundle__milestone-label {
    position: absolute; top: calc(100% + 4px);
    font-size: 10px; font-weight: 700; letter-spacing: 0.3px; text-transform: uppercase;
    color: var(--zk-ink-faded); white-space: nowrap;
    transition: color 200ms ease;
  }
  .zk-bundle__milestone[data-reached="true"] .zk-bundle__milestone-dot {
    background: var(--zk-cta); border-color: var(--zk-cta); color: #fff;
    box-shadow: 0 2px 8px rgba(232, 93, 58, 0.35);
  }
  .zk-bundle__milestone[data-reached="true"] .zk-bundle__milestone-label {
    color: var(--zk-cta);
  }

  /* Carousel */
  .zk-bundle__carousel {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(180px, 1fr);
    gap: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 4px 2px 14px;
    margin: 0 -4px 0 -4px;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
  }
  .zk-bundle__carousel::-webkit-scrollbar { height: 6px; }
  .zk-bundle__carousel::-webkit-scrollbar-track { background: transparent; }
  .zk-bundle__carousel::-webkit-scrollbar-thumb { background: var(--zk-border); border-radius: 999px; }

  .zk-bundle__card {
    scroll-snap-align: start;
    display: flex; flex-direction: column; gap: 8px;
    background: var(--zk-surface);
    border: 1px solid var(--zk-border);
    border-radius: 14px;
    padding: 10px; min-width: 0;
  }
  .zk-bundle__media {
    display: block; aspect-ratio: 1 / 1;
    border-radius: 10px; overflow: hidden; background: var(--zk-bg-deep);
  }
  .zk-bundle__media img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .zk-bundle__info {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 6px; margin-top: 2px;
  }
  .zk-bundle__name {
    font-size: 13px; font-weight: 600; line-height: 1.25;
    color: var(--zk-ink); text-decoration: none;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    flex: 1 1 auto; min-width: 0;
  }
  .zk-bundle__name:hover { text-decoration: underline; }
  .zk-bundle__price {
    font-size: 13px; font-weight: 700; color: var(--zk-ink); flex: 0 0 auto;
  }

  .zk-bundle__options { display: flex; flex-direction: column; gap: 5px; margin-top: 2px; }
  .zk-bundle__option { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  .zk-bundle__option-label {
    font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    color: var(--zk-ink-faded); flex: 0 0 auto; min-width: 30px;
  }
  .zk-bundle__option-values { display: flex; flex-wrap: wrap; gap: 3px; }
  .zk-bundle__option-btn {
    appearance: none; background: var(--zk-surface); border: 1px solid var(--zk-border);
    border-radius: 4px; padding: 3px 7px; font-size: 11px; font-weight: 600;
    color: var(--zk-ink); cursor: pointer; transition: all 120ms ease;
    line-height: 1.2; min-width: 22px; font-family: inherit;
  }
  .zk-bundle__option-btn:hover { border-color: var(--zk-ink); }
  .zk-bundle__option-btn[aria-checked="true"] {
    background: var(--zk-ink); border-color: var(--zk-ink); color: #fff;
  }
  .zk-bundle__swatch {
    appearance: none; width: 18px; height: 18px; border-radius: 50%;
    border: 1px solid var(--zk-border-strong); padding: 0; cursor: pointer;
    transition: outline 120ms ease; font-family: inherit; position: relative; flex: 0 0 auto;
  }
  .zk-bundle__swatch[aria-checked="true"] {
    outline: 2px solid var(--zk-ink); outline-offset: 2px;
  }
  .zk-bundle__swatch-label {
    position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
  }

  .zk-bundle__add {
    appearance: none; background: var(--zk-cta); color: #fff;
    border: 1px solid var(--zk-cta); border-radius: 8px; padding: 8px 10px;
    font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
    cursor: pointer; transition: background 150ms ease, border-color 150ms ease;
    min-height: 34px; display: flex; align-items: center; justify-content: center;
    gap: 6px; font-family: inherit; margin-top: auto;
  }
  .zk-bundle__add:hover:not(:disabled) { background: var(--zk-cta-hover); border-color: var(--zk-cta-hover); }
  .zk-bundle__add:disabled {
    background: var(--zk-muted); border-color: var(--zk-muted); color: #fff;
    cursor: not-allowed; opacity: 0.85;
  }
  .zk-bundle__add[data-state="success"] {
    background: var(--zk-success) !important; border-color: var(--zk-success) !important; opacity: 1 !important;
  }
  .zk-bundle__spinner {
    width: 12px; height: 12px;
    border: 2px solid rgba(255,255,255,0.35); border-top-color: #fff;
    border-radius: 50%; animation: zk-spin 600ms linear infinite;
    display: inline-block;
  }
  @keyframes zk-spin { to { transform: rotate(360deg); } }

  .zk-bundle__foot {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    font-size: 11px; color: var(--zk-ink-faded); margin: 4px 0 0; font-weight: 500;
  }
  .zk-bundle__foot-icon { flex-shrink: 0; color: var(--zk-success); }

  @media (max-width: 640px) {
    .zk-bundle__inner { padding: 16px 14px 12px; border-radius: 14px; }
    .zk-bundle__title { font-size: 17px; }
    .zk-bundle__message { font-size: 13px; }
    .zk-bundle__carousel { grid-auto-columns: 160px; }
    .zk-bundle__card { padding: 8px; }
    .zk-bundle__milestone-dot { width: 24px; height: 24px; font-size: 10px; }
    .zk-bundle__milestone-label { font-size: 9px; }
  }
  @media (min-width: 900px) {
    .zk-bundle__carousel { grid-auto-columns: minmax(200px, 1fr); }
  }
</style>

<script>
(function() {
  'use strict';

  /* ========== One-time global setup (shared across both slots) ========== */
  if (!window.__zkBundleGlobal) {
    window.__zkBundleGlobal = true;

    // Suppress third-party cart drawers triggered by our adds.
    // Any node with these classes gets force-closed 200ms after a cart mutation.
    var DRAWER_SELECTORS = [
      '.cart-drawer.is-open', '.cart-drawer--open', '.drawer--open',
      '[data-cart-drawer].is-open', '.js-drawer-open', '.drawer.is-visible',
      '.slide-cart.is-open', '.ajax-cart--open', '.mini-cart.is-open',
      'cart-drawer[open]', 'cart-drawer.is-open'
    ];
    var BODY_DRAWER_CLASSES = ['drawer-open', 'js-drawer-open', 'no-scroll', 'overflow-hidden', 'cart-drawer-open'];

    window.__zkBundleForceCloseDrawer = function() {
      try {
        DRAWER_SELECTORS.forEach(function(sel) {
          document.querySelectorAll(sel).forEach(function(el) {
            el.classList.remove('is-open', 'is-active', 'is-visible', 'drawer--open', 'cart-drawer--open', 'ajax-cart--open', 'mini-cart--open', 'slide-cart--open', 'js-drawer-open');
            if (el.hasAttribute('open')) el.removeAttribute('open');
            el.setAttribute('aria-hidden', 'true');
          });
        });
        BODY_DRAWER_CLASSES.forEach(function(cls) { document.body.classList.remove(cls); });
      } catch (e) {}
    };

    // Refresh all bundle instances' progress state
    window.__zkBundleRefreshAll = function() {
      document.querySelectorAll('.zk-bundle').forEach(function(root) {
        if (root.__zkRefresh) root.__zkRefresh();
      });
    };

    // Hook fetch to detect ANY cart mutation (main PDP ATC, Candy Rack, etc.)
    // so the progress bar updates even when other code triggers cart changes.
    if (window.fetch && !window.__zkBundleFetchHooked) {
      window.__zkBundleFetchHooked = true;
      var origFetch = window.fetch;
      window.fetch = function(input, init) {
        var url = '';
        try { url = typeof input === 'string' ? input : (input && input.url) || ''; } catch(e){}
        var isCartMut = /\/cart\/(add|change|update|clear)(\.js)?/i.test(url);
        var p = origFetch.apply(this, arguments);
        if (isCartMut) {
          p.then(function() {
            setTimeout(window.__zkBundleRefreshAll, 250);
          }).catch(function(){});
        }
        return p;
      };
    }
  }

  /* ========== Per-instance init ========== */
  var roots = document.querySelectorAll('.zk-bundle');
  roots.forEach(function(root) {
    if (root.dataset.zkBundleInit === '1') return;
    root.dataset.zkBundleInit = '1';

    var tiers = (root.dataset.zkTiers || '2,3').split(',').map(function(n) { return parseInt(n, 10); });
    var bundleProductIds = (root.dataset.zkProductIds || '').split(',')
      .map(function(id) { return parseInt(id, 10); })
      .filter(function(id) { return !isNaN(id); });

    var fillEl = root.querySelector('[data-zk-progress-fill]');
    var messageEl = root.querySelector('[data-zk-message]');
    var milestoneEls = root.querySelectorAll('[data-zk-milestone]');

    function buildMessage(count) {
      var maxTier = tiers[tiers.length - 1];
      if (count <= 0) {
        if (tiers.indexOf(4) >= 0) return 'Pick any 2 for $5 off. Any 3 for $10 off. Any 4+ for $20 off.';
        return 'Pick any 2 for $5 off. Any 3 for $10 off.';
      }
      if (count === 1) return 'Add 1 more for $5 off.';
      if (count === 2 && tiers.indexOf(3) >= 0) return 'Saving $5 — add 1 more for $10 off.';
      if (count === 2) return 'Saving $5 unlocked.';
      if (count === 3 && tiers.indexOf(4) >= 0) return 'Saving $10 — add 1 more for $20 off.';
      if (count === 3) return 'Saving $10 unlocked.';
      if (count >= maxTier) return maxTier === 4 ? 'Max saving unlocked — $20 off.' : 'Max saving unlocked — $10 off.';
      return '';
    }

    function progressPct(count) {
      if (tiers.length === 3) {
        if (count >= 4) return 100;
        if (count >= 3) return 66;
        if (count >= 2) return 33;
        if (count >= 1) return 16.5;
        return 0;
      } else {
        if (count >= 3) return 100;
        if (count >= 2) return 50;
        if (count >= 1) return 25;
        return 0;
      }
    }

    function updateProgress(count) {
      if (fillEl) fillEl.style.width = progressPct(count) + '%';
      milestoneEls.forEach(function(el) {
        var threshold = parseInt(el.dataset.zkMilestone, 10);
        el.dataset.reached = count >= threshold ? 'true' : 'false';
      });
      if (messageEl) {
        var msg = buildMessage(count);
        if (msg) messageEl.textContent = msg;
      }
    }

    function countBundleItemsInCart() {
      return new Promise(function(resolve) {
        var xhr = new XMLHttpRequest();
        xhr.open('GET', '/cart.js', true);
        xhr.setRequestHeader('Accept', 'application/json');
        xhr.onreadystatechange = function() {
          if (xhr.readyState === 4) {
            try {
              var cart = JSON.parse(xhr.responseText);
              if (!cart || !cart.items) return resolve(0);
              var count = 0;
              cart.items.forEach(function(item) {
                if (bundleProductIds.indexOf(item.product_id) >= 0) count += item.quantity;
              });
              resolve(count);
            } catch (e) { resolve(0); }
          }
        };
        xhr.send();
      });
    }

    function refreshCartState() {
      countBundleItemsInCart().then(updateProgress);
    }

    // Expose for global refresh
    root.__zkRefresh = refreshCartState;

    // Initial render
    refreshCartState();

    /* ===== Per-card: variant picker + add ===== */
    root.querySelectorAll('[data-zk-item]').forEach(function(item) {
      var variantsNode = item.querySelector('[data-zk-variants]');
      if (!variantsNode) return;
      var variants;
      try { variants = JSON.parse(variantsNode.textContent); } catch (e) { return; }

      var addBtn = item.querySelector('[data-zk-add]');
      var optionEls = item.querySelectorAll('.zk-bundle__option');
      var selection = {};

      function allSelected() { return optionEls.length === Object.keys(selection).length; }
      function findVariant() {
        return variants.find(function(v) {
          return v.options.every(function(val, i) { return val === selection[i]; });
        });
      }
      function updateAddState() {
        var defaultEl = addBtn.querySelector('.zk-bundle__add-default');
        if (!allSelected()) {
          addBtn.disabled = true; addBtn.setAttribute('aria-disabled', 'true');
          defaultEl.textContent = 'Select options'; return;
        }
        var v = findVariant();
        if (!v) { addBtn.disabled = true; defaultEl.textContent = 'Unavailable'; return; }
        if (!v.available) { addBtn.disabled = true; defaultEl.textContent = 'Sold out'; return; }
        addBtn.disabled = false;
        addBtn.setAttribute('aria-disabled', 'false');
        addBtn.dataset.variantId = v.id;
        defaultEl.textContent = 'Add';
      }

      optionEls.forEach(function(optEl) {
        var idx = parseInt(optEl.dataset.optionIndex, 10);
        var btns = optEl.querySelectorAll('.zk-bundle__option-btn, .zk-bundle__swatch');
        btns.forEach(function(btn) {
          btn.addEventListener('click', function() {
            btns.forEach(function(b) { b.setAttribute('aria-checked', 'false'); });
            btn.setAttribute('aria-checked', 'true');
            selection[idx] = btn.dataset.optionValue;
            updateAddState();
          });
        });
      });

      if (!addBtn) return;

      // XHR-based add bypasses fetch monkey-patches from other apps that
      // might open a cart drawer on fetch('/cart/add.js').
      function addToCartXHR(variantId) {
        return new Promise(function(resolve, reject) {
          var xhr = new XMLHttpRequest();
          xhr.open('POST', '/cart/add.js', true);
          xhr.setRequestHeader('Content-Type', 'application/json');
          xhr.setRequestHeader('Accept', 'application/json');
          xhr.onreadystatechange = function() {
            if (xhr.readyState === 4) {
              if (xhr.status >= 200 && xhr.status < 300) {
                try { resolve(JSON.parse(xhr.responseText)); } catch (e) { resolve({}); }
              } else reject(new Error('add failed: ' + xhr.status));
            }
          };
          xhr.send(JSON.stringify({ id: variantId, quantity: 1 }));
        });
      }

      addBtn.addEventListener('click', function(e) {
        e.preventDefault();
        e.stopPropagation();
        var variantId = addBtn.dataset.variantId;
        if (!variantId || addBtn.disabled) return;
        addBtn.disabled = true;
        addBtn.dataset.state = 'loading';
        var defaultEl = addBtn.querySelector('.zk-bundle__add-default');
        var loadingEl = addBtn.querySelector('.zk-bundle__add-loading');
        var successEl = addBtn.querySelector('.zk-bundle__add-success');
        defaultEl.hidden = true;
        loadingEl.hidden = false;

        addToCartXHR(parseInt(variantId, 10))
          .then(function() {
            addBtn.dataset.state = 'success';
            loadingEl.hidden = true;
            successEl.hidden = false;
            // Force-close any drawer that opened from this cart mutation
            setTimeout(window.__zkBundleForceCloseDrawer, 150);
            setTimeout(window.__zkBundleForceCloseDrawer, 500);
            refreshCartState();
            setTimeout(function() {
              addBtn.dataset.state = '';
              successEl.hidden = true;
              defaultEl.hidden = false;
              addBtn.disabled = false;
            }, 2000);
          })
          .catch(function(err) {
            console.error('[zk-bundle]', err);
            addBtn.dataset.state = '';
            loadingEl.hidden = true;
            defaultEl.hidden = false;
            defaultEl.textContent = 'Try again';
            setTimeout(function() {
              defaultEl.textContent = 'Add';
              addBtn.disabled = false;
            }, 2000);
          });
      });
    });
  });
})();
</script>

  {%- endif -%}
{%- endif -%}
