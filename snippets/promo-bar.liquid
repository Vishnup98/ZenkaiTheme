{%- comment -%}
  Promo Bar — site-wide slim strip above the header.
  Informational only (not a link) so shoppers aren't yanked away from their
  current page. Copy emphasizes "any product, any category" for clarity.
  Styling uses the shared .bundle-eyebrow pattern that repeats across every
  bundle promo surface (cart, collection belt, homepage band, PDP callout).
{%- endcomment -%}

<div class="zk-promo-bar" role="status" aria-label="Bundle promotion">
  <div class="zk-promo-bar__inner">
    <span class="bundle-eyebrow bundle-eyebrow--light" aria-hidden="true">
      <span class="bundle-eyebrow__dot"></span>
      <span class="bundle-eyebrow__text">Bundle &amp; save</span>
    </span>
    <span class="zk-promo-bar__text">{% include 'bundle-tiers', format: 'short' %}</span>
  </div>
</div>

<style>
  .zk-promo-bar {
    width: 100%;
    background: #5966cf;
    color: #ffffff;
    padding: 9px 16px;
    text-align: center;
    font-family: inherit;
    font-size: 12px;
    letter-spacing: 0.04em;
    line-height: 1.4;
  }
  .zk-promo-bar__inner {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    max-width: 100%;
  }
  .zk-promo-bar__text { font-weight: 500; }

  /* ── Shared bundle eyebrow (see also: cart tier, collection belt,
     homepage band). Swap .bundle-eyebrow--light for dark contexts. ── */
  .bundle-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #1a1b2e;
    white-space: nowrap;
  }
  .bundle-eyebrow__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #5966cf;
    display: inline-block;
    flex-shrink: 0;
  }
  .bundle-eyebrow--light { color: #ffffff; }
  .bundle-eyebrow--light .bundle-eyebrow__dot { background: #ffffff; }

  @media (max-width: 640px) {
    .zk-promo-bar { font-size: 11px; padding: 8px 12px; }
    .zk-promo-bar__inner { gap: 8px; }
    .bundle-eyebrow { font-size: 9px; letter-spacing: 0.12em; gap: 6px; }
  }
</style>
