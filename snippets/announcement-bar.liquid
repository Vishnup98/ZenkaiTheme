{%- assign zenkai_is_product_page = false -%}
{% if template contains 'product' %}
  {%- assign zenkai_is_product_page = true -%}
{% endif %}

<div class="announcement">
  <div class="announcement__wrapper">
    {% if section.settings.announcement_link != blank %}
      <a href="{{ section.settings.announcement_link }}" class="announcement__link">
    {% endif %}

    <div class="announcement__text announcement__text--rotating"
         data-rotating-messages='["Free U.S. shipping", "Ships in 1–2 days", "Nostalgia, drawn properly"]'>
      {{ section.settings.announcement_text | strip_html }}
    </div>

    {% if section.settings.announcement_link != blank %}
      </a>
    {% endif %}
  </div>
</div>

<script>
(function() {
  const textEl = document.querySelector('.announcement__text--rotating');
  if (!textEl) return;

  const messages = JSON.parse(textEl.dataset.rotatingMessages || '[]');
  if (messages.length < 2) return;

  // Paint messages[0] immediately so the longer settings text doesn't flash
  // for 4s before the first rotation tick. Index increments AFTER display,
  // so the cycle reads [0, 1, 2, 0, …] instead of skipping 0.
  let currentIndex = 0;
  textEl.textContent = messages[0];

  function rotateMessage() {
    textEl.style.opacity = '0';

    setTimeout(() => {
      currentIndex = (currentIndex + 1) % messages.length;
      textEl.textContent = messages[currentIndex];
      textEl.style.opacity = '1';
    }, 300);
  }

  setInterval(rotateMessage, 4000);
})();
</script>

<style>
.announcement__text--rotating {
  transition: opacity 0.3s ease;
  will-change: opacity;
}
/* Night Signal - Midnight Indigo Announcement Bar */
.announcement {
  background: #1a1b2e !important;
}
.announcement__text,
.announcement__link,
.announcement__text--rotating {
  color: #ffffff !important;
}
{% if template contains 'product' %}
  .announcement__wrapper {
    min-height: 30px;
  }

  .announcement__text,
  .announcement__link,
  .announcement__text--rotating,
  .announcement__text--static {
    font-size: 10px;
    letter-spacing: 0.16em;
    line-height: 1.2;
    padding-top: 6px;
    padding-bottom: 6px;
  }
{% endif %}
</style>
