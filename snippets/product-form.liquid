{%- assign zenkai_cta_text = product_cta_text | default: 'Claim Yours' -%}
{%- assign zenkai_cta_note = product_cta_note | default: 'Made to order. Production starts as soon as you reserve your size.' -%}
{%- assign zenkai_urgency_chip = product_urgency_chip | default: 'Printed to order in the USA' -%}
{%- assign zenkai_secondary_checkout = false -%}
{% if show_dynamic_checkout_secondary %}
  {%- assign zenkai_secondary_checkout = true -%}
{% endif %}

{% capture form_id %}AddToCartForm-{{ section_id }}{% endcapture %}
{% form 'product', product, id: form_id, class: 'product-single__form small--text-center' %}
  <input type="hidden" name="data-product-id" value="{{ product.id }}">
  {% unless product.has_only_default_variant %}
    {% for option in product.options_with_values %}
      {% if variant_type == 'button' %}
        {% include 'variant-button', section_id: section_id, option_drop: option %}
      {% else %}
        {% include 'variant-dropdown', section_id: section_id %}
      {% endif %}
    {% endfor %}
  {% endunless %}

  <select name="id" id="ProductSelect-{{ section_id }}" class="product-single__variants no-js" data-product-select>
    {% for variant in product.variants %}
      {% if variant.available %}
        <option {% if variant == product.selected_or_first_available_variant %}
          selected="selected" {% endif %}
          value="{{ variant.id }}">
          {{ variant.title }} - {{ variant.price | money_with_currency }}
        </option>
      {% else %}
        <option disabled="disabled">
          {{ variant.title }} - {{ 'products.product.sold_out' | t }}
        </option>
      {% endif %}
    {% endfor %}
  </select>

  {% if quantity_enable %}
    <div class="product__quantity product__quantity--{{ variant_type }}">
      <label for="Quantity-{{ section_id }}" class="variant__label">{{ 'products.product.quantity' | t }}</label>
      <input type="number" id="Quantity-{{ section_id }}" name="quantity" value="1" min="1">
    </div>
  {% endif %}

  {%- assign enable_dynamic_buttons = false -%}
  {% if enable_payment_button and zenkai_secondary_checkout and template != 'product.preorder' %}
    {%- assign enable_dynamic_buttons = true -%}
  {% endif %}

  <div class="zenkai-product-actions" data-product-form-anchor>
    <p class="zenkai-form-chip">{{ zenkai_urgency_chip }}</p>
    <button
      {% if product.empty? %}type="button"{% else %}type="submit"{% endif %}
      name="add"
      data-add-to-cart
      data-cta-label="{{ zenkai_cta_text | escape }}"
      class="btn btn--full add-to-cart zenkai-primary-cta{% if enable_dynamic_buttons %} zenkai-primary-cta--with-secondary{% endif %}"
      {% unless current_variant.available %} disabled="disabled"{% endunless %}>
      <span data-add-to-cart-text>
        {% if current_variant.available %}
          {% if template == 'product.preorder' %}
            {{ 'products.product.preorder' | t }}
          {% else %}
            {{ zenkai_cta_text }}
          {% endif %}
        {% else %}
          {{ 'products.product.sold_out' | t }}
        {% endif %}
      </span>
    </button>
    <p class="zenkai-cta-note">{{ zenkai_cta_note }}</p>
  </div>

  {% if enable_dynamic_buttons %}
    <div class="zenkai-secondary-checkout">
      {{ form | payment_button }}
    </div>
  {% endif %}

  {% unless product.empty? %}
    <div class="hide" aria-hidden="true" data-variant-json>
      {{ product.variants | json }}
    </div>
    {% if product.options.size > 1 %}
      <div class="hide" aria-hidden="true" data-current-variant-json>
        {{ current_variant | json }}
      </div>
    {% endif %}
  {% endunless %}

{% endform %}
