{%- assign zenkai_cta_text = product_cta_text | default: 'Add to Cart' -%}
{%- assign zenkai_cta_subcopy = product_cta_subcopy | default: product_cta_note | default: 'Free U.S. shipping. Printed to order.' -%}
{%- assign zenkai_secondary_checkout = true -%}
{% if show_dynamic_checkout_secondary == false %}
  {%- assign zenkai_secondary_checkout = false -%}
{% endif %}

{% capture form_id %}AddToCartForm-{{ section_id }}{% endcapture %}
{% form 'product', product, id: form_id, class: 'product-single__form zenkai-product-form small--text-center' %}
  <input type="hidden" name="data-product-id" value="{{ product.id }}">
  {% unless product.has_only_default_variant %}
    {% for option in product.options_with_values %}
      {% if variant_type == 'button' %}
        {% include 'variant-button', section_id: section_id, option_drop: option %}
      {% else %}
        {% include 'variant-dropdown', section_id: section_id %}
      {% endif %}
    {% endfor %}
  {% endunless %}

  <select name="id" id="ProductSelect-{{ section_id }}" class="product-single__variants no-js" data-product-select>
    {% for variant in product.variants %}
      {% if variant.available %}
        <option {% if variant == product.selected_or_first_available_variant %}
          selected="selected" {% endif %}
          value="{{ variant.id }}">
          {{ variant.title }} - {{ variant.price | money_with_currency }}
        </option>
      {% else %}
        <option disabled="disabled">
          {{ variant.title }} - {{ 'products.product.sold_out' | t }}
        </option>
      {% endif %}
    {% endfor %}
  </select>

  {% if quantity_enable %}
    <div class="product__quantity product__quantity--{{ variant_type }}">
      <label for="Quantity-{{ section_id }}" class="variant__label">{{ 'products.product.quantity' | t }}</label>
      <input type="number" id="Quantity-{{ section_id }}" name="quantity" value="1" min="1" max="99">
    </div>
  {% endif %}

  {%- assign enable_dynamic_buttons = false -%}
  {% if enable_payment_button and zenkai_secondary_checkout and template != 'product.preorder' %}
    {%- assign enable_dynamic_buttons = true -%}
  {% endif %}

  <p class="zenkai-fit-note">Runs true to size · Retail fit, not boxy</p>

  {% if zenkai_primary_proof_quote != blank %}
    <div class="zenkai-proof-nudge" aria-label="Customer review">
      <span class="zenkai-proof-nudge__quote">"{{ zenkai_primary_proof_quote }}"</span>
      <span class="zenkai-proof-nudge__attr">— {{ zenkai_primary_proof_attribution | default: 'Verified buyer' }}</span>
    </div>
  {% endif %}

  <div class="zenkai-product-actions" data-product-form-anchor>
    <div class="zenkai-trust-strip">
      <span class="zenkai-trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
        Free U.S. shipping on every order
      </span>
      <span class="zenkai-trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
        1,200+ orders shipped and counting
      </span>
      <span class="zenkai-trust-item">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
        Premium ring-spun cotton · Not thin, not boxy
      </span>
    </div>
    <button
      {% if product.empty? %}type="button"{% else %}type="submit"{% endif %}
      name="add"
      data-add-to-cart
      data-cta-label="{{ zenkai_cta_text | escape }}"
      aria-live="polite"
      class="btn btn--full add-to-cart zenkai-primary-cta{% if enable_dynamic_buttons %} zenkai-primary-cta--with-secondary{% endif %}"
      {% unless current_variant.available %} disabled="disabled"{% endunless %}>
      <span data-add-to-cart-text>
        {% if current_variant.available %}
          {% if template == 'product.preorder' %}
            {{ 'products.product.preorder' | t }}
          {% else %}
            {{ zenkai_cta_text }}
          {% endif %}
        {% else %}
          {{ 'products.product.sold_out' | t }}
        {% endif %}
      </span>
    </button>
  </div>

  {% if enable_dynamic_buttons %}
    <div class="zenkai-secondary-checkout">
      {{ form | payment_button }}
    </div>
  {% endif %}

  {% unless product.empty? %}
    <div class="hide" aria-hidden="true" data-variant-json>
      {{ product.variants | json }}
    </div>
    {% if product.options.size > 1 %}
      <div class="hide" aria-hidden="true" data-current-variant-json>
        {{ current_variant | json }}
      </div>
    {% endif %}
  {% endunless %}

{% endform %}
